{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
      "baseUrl": ".",
      "paths": {
          "@pages/*": ["src/pages/*"],
          "@layouts/*": ["src/layouts/*"],
          "@styles/*": ["src/styles/*"],
          "@components/*": ["src/components/*"]
      }
  }
}
