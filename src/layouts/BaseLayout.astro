---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import PostHog from '@components/posthog.astro';
import '@styles/global.css';
import { convex } from '@lib/convex';
import { api } from '@convex/api';

interface Props {
  title: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown>;
}

const {
  title,
  description = 'c4studio BAS',
  image = '/og-image.svg',
  schema,
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;

const settings = await convex.query(api.settings.get, {});
const pathname = Astro.url.pathname;
const bypassMaintenance =
  pathname.startsWith('/admin') ||
  pathname.startsWith('/dashboard') ||
  pathname.startsWith('/sign-in') ||
  pathname.startsWith('/sign-up');
const maintenanceActive = !bypassMaintenance && (settings?.maintenanceMode ?? false);
const appName = settings?.appName ?? 'c4studio';
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={image} />

    <!-- Brand Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- JSON-LD Structured Data -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <slot name="head" />
    <ClientRouter />
    <PostHog />
  </head>

  <body class="antialiased">
    <a
      class="sr-only focus:not-sr-only focus:absolute focus:z-[99999] focus:bg-black focus:text-white focus:px-4 focus:py-2 focus:rounded-md"
      href="#main"
    >
      Skip to main content
    </a>

    {maintenanceActive && (
      <div class="fixed inset-0 z-[99999] min-h-screen bg-slate-900 flex flex-col items-center justify-center px-6 text-center">
        <div class="w-16 h-16 rounded-2xl bg-slate-800 flex items-center justify-center mb-8">
          <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.653-4.655m5.8-5.8 1.5-1.5a2.121 2.121 0 0 1 3 3l-1.5 1.5m-5.8 5.8-5.8-5.8"/>
          </svg>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight mb-4" style="font-family: 'Lexend', sans-serif;">
          We'll be right back.
        </h1>
        <p class="text-slate-400 text-lg max-w-md" style="font-family: 'Inter', sans-serif;">
          We're making some improvements. Check back soon.
        </p>
        <p class="text-slate-600 text-sm mt-6" style="font-family: 'Inter', sans-serif;">{appName}</p>
      </div>
    )}

    <slot name="header" />

    <main id="main" transition:animate="fade">
      <slot />
    </main>

    <slot name="footer" />
    <Analytics />
  </body>
</html>
