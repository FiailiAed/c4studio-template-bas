---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats?: Stat[];
}

const {
  stats = [
    { value: '200+', label: 'Happy clients' },
    { value: '500+', label: 'Projects delivered' },
    { value: '8+',   label: 'Years in business' },
    { value: '4.9',  label: 'Average rating' },
  ],
} = Astro.props;
---

<section class="bg-slate-50 border-y border-slate-200">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
      {stats.map(({ value, label }) => (
        <div class="flex flex-col items-center text-center gap-1">
          <p class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight" style="font-family: 'Lexend', sans-serif;">{value}</p>
          <p class="text-sm text-slate-500" style="font-family: 'Inter', sans-serif;">{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
