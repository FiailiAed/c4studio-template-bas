---
interface Props {
  appName?: string;
  tagline?: string;
}

const {
  appName = 'c4studio',
  tagline = 'Building digital products people love.',
} = Astro.props;

const nav = {
  Company: [
    { label: 'About',   href: '/about' },
    { label: 'Blog',    href: '/blog' },
    { label: 'Gallery', href: '/gallery' },
    { label: 'Contact', href: '/contact' },
  ],
  Services: [
    { label: 'Strategy',     href: '/services#strategy' },
    { label: 'Design',       href: '/services#design' },
    { label: 'Development',  href: '/services#development' },
    { label: 'Growth',       href: '/services#growth' },
  ],
  Legal: [
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Terms of Use',   href: '/terms' },
  ],
};

const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-14">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block text-lg font-bold text-white tracking-tight mb-3" style="font-family: 'Lexend', sans-serif;">
          {appName}
        </a>
        <p class="text-sm leading-relaxed mb-6" style="font-family: 'Inter', sans-serif;">{tagline}</p>

        <!-- Social links -->
        <div class="flex gap-3">
          {[
            { label: 'Twitter / X', href: '#', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
            { label: 'LinkedIn',    href: '#', icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
            { label: 'GitHub',      href: '#', icon: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12' },
          ].map(({ label, href, icon }) => (
            <a
              href={href}
              aria-label={label}
              class="w-8 h-8 rounded-lg bg-slate-800 hover:bg-slate-700 flex items-center justify-center transition"
            >
              <svg class="w-3.5 h-3.5 text-slate-400" fill="currentColor" viewBox="0 0 24 24">
                <path d={icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Nav columns -->
      {Object.entries(nav).map(([group, links]) => (
        <div>
          <p class="text-xs font-semibold text-white uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">{group}</p>
          <ul class="flex flex-col gap-2.5">
            {links.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-slate-400 hover:text-white transition"
                  style="font-family: 'Inter', sans-serif;"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-600" style="font-family: 'Inter', sans-serif;">
        &copy; {year} {appName}. All rights reserved.
      </p>
      <p class="text-xs text-slate-600" style="font-family: 'Inter', sans-serif;">
        Built with c4studio B.A.S.
      </p>
    </div>
  </div>
</footer>
