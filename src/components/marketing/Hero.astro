---
interface Props {
  headline?: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  headline = 'Build something\npeople love.',
  subheadline = 'We help ambitious businesses design, build, and grow digital products that stand out.',
  primaryCta = { label: 'Get started', href: '/contact' },
  secondaryCta = { label: 'See our work', href: '/gallery' },
} = Astro.props;
---

<section class="relative overflow-hidden bg-slate-900 text-white">
  <!-- Background grid pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>

  <!-- Gradient orb -->
  <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-600/20 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-40 -left-20 w-[400px] h-[400px] rounded-full bg-sky-500/15 blur-3xl pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-28 md:py-36 lg:py-44">
    <div class="max-w-3xl">
      <!-- Eyebrow -->
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-sky-400 uppercase tracking-widest mb-6" style="font-family: 'Inter', sans-serif;">
        <span class="w-6 h-px bg-sky-400"></span>
        Welcome
      </p>

      <!-- Headline -->
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] mb-6 whitespace-pre-line" style="font-family: 'Lexend', sans-serif;">
        {headline}
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-slate-400 leading-relaxed mb-10 max-w-2xl" style="font-family: 'Inter', sans-serif;">
        {subheadline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href={primaryCta.href}
          class="inline-flex items-center gap-2 text-sm font-semibold bg-white text-slate-900 px-6 py-3.5 rounded-xl hover:bg-slate-100 transition"
          style="font-family: 'Inter', sans-serif;"
        >
          {primaryCta.label}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
        <a
          href={secondaryCta.href}
          class="inline-flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-white border border-slate-700 hover:border-slate-500 px-6 py-3.5 rounded-xl transition"
          style="font-family: 'Inter', sans-serif;"
        >
          {secondaryCta.label}
        </a>
      </div>
    </div>
  </div>
</section>
