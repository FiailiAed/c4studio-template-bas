---
interface Props {
  heading?: string;
  subheading?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  heading = 'Ready to build\nsomething great?',
  subheading = 'Let\'s talk about your project. We typically respond within one business day.',
  primaryCta = { label: 'Start a project', href: '/contact' },
  secondaryCta = { label: 'See our work', href: '/gallery' },
} = Astro.props;
---

<section class="bg-slate-900 text-white py-24 md:py-32 relative overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-blue-600/20 blur-3xl pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-6 whitespace-pre-line" style="font-family: 'Lexend', sans-serif;">
      {heading}
    </h2>
    <p class="text-lg text-slate-400 leading-relaxed mb-10 max-w-xl mx-auto" style="font-family: 'Inter', sans-serif;">
      {subheading}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={primaryCta.href}
        class="inline-flex items-center gap-2 text-sm font-semibold bg-white text-slate-900 px-6 py-3.5 rounded-xl hover:bg-slate-100 transition"
        style="font-family: 'Inter', sans-serif;"
      >
        {primaryCta.label}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
      <a
        href={secondaryCta.href}
        class="inline-flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-white border border-slate-700 hover:border-slate-500 px-6 py-3.5 rounded-xl transition"
        style="font-family: 'Inter', sans-serif;"
      >
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>
