---
interface GalleryItem {
  src: string;
  alt: string;
  span?: 'normal' | 'wide' | 'tall';
}

interface Props {
  eyebrow?: string;
  heading?: string;
  items?: GalleryItem[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  eyebrow = 'Our work',
  heading = 'Built to\nbe seen.',
  ctaHref = '/gallery',
  ctaLabel = 'View full gallery',
  items = [],
} = Astro.props;

// Placeholder grid — 6 slots with varying aspect ratios
const placeholders = [
  { label: 'Project 1', bg: 'bg-slate-200', aspect: 'aspect-video' },
  { label: 'Project 2', bg: 'bg-blue-100',  aspect: 'aspect-square' },
  { label: 'Project 3', bg: 'bg-sky-100',   aspect: 'aspect-square' },
  { label: 'Project 4', bg: 'bg-slate-100', aspect: 'aspect-video' },
  { label: 'Project 5', bg: 'bg-slate-200', aspect: 'aspect-square' },
  { label: 'Project 6', bg: 'bg-blue-100',  aspect: 'aspect-square' },
];
---

<section class="bg-slate-50 py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
      <div class="max-w-xl">
        <p class="inline-flex items-center gap-2 text-xs font-semibold text-blue-600 uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">
          <span class="w-6 h-px bg-blue-600"></span>
          {eyebrow}
        </p>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight leading-tight whitespace-pre-line" style="font-family: 'Lexend', sans-serif;">
          {heading}
        </h2>
      </div>
      <a
        href={ctaHref}
        class="shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 transition inline-flex items-center gap-2"
        style="font-family: 'Inter', sans-serif;"
      >
        {ctaLabel}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>

    {items.length > 0 ? (
      <!-- Real gallery items from Convex -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {items.map(({ src, alt }) => (
          <div class="rounded-2xl overflow-hidden aspect-square bg-slate-200">
            <img src={src} alt={alt} class="w-full h-full object-cover hover:scale-105 transition duration-500" loading="lazy" />
          </div>
        ))}
      </div>
    ) : (
      <!-- Placeholder grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {placeholders.map(({ label, bg, aspect }) => (
          <div class={`rounded-2xl overflow-hidden ${aspect} ${bg} flex items-center justify-center group cursor-pointer hover:brightness-95 transition`}>
            <div class="flex flex-col items-center gap-2 text-slate-400">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
              </svg>
              <p class="text-xs font-medium" style="font-family: 'Inter', sans-serif;">{label}</p>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
