---
interface Review {
  body: string;
  authorName: string;
  authorTitle?: string;
  rating?: number;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  reviews?: Review[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  eyebrow = 'Testimonials',
  heading = 'Loved by the\npeople we serve.',
  ctaHref = '/reviews',
  ctaLabel = 'See all reviews',
  reviews = [
    {
      body: 'The team delivered an exceptional product — on time, on budget, and with a level of care that made all the difference. We saw a 40% jump in conversions within weeks of launch.',
      authorName: 'Alex Rivera',
      authorTitle: 'CEO, Meridian Labs',
      rating: 5,
    },
    {
      body: 'Working with them felt like having a world-class in-house team. They challenged our assumptions in the best way and built something we genuinely love using every day.',
      authorName: 'Jordan Kim',
      authorTitle: 'Founder, Flowstate',
      rating: 5,
    },
    {
      body: 'From the first call I knew this was different. No fluff, no filler — just honest, strategic thinking and beautiful execution. Highly recommend to anyone serious about their product.',
      authorName: 'Sam Chen',
      authorTitle: 'Product Lead, Orbit Co.',
      rating: 5,
    },
  ],
} = Astro.props;
---

<section class="bg-white py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
      <div class="max-w-xl">
        <p class="inline-flex items-center gap-2 text-xs font-semibold text-blue-600 uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">
          <span class="w-6 h-px bg-blue-600"></span>
          {eyebrow}
        </p>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight leading-tight whitespace-pre-line" style="font-family: 'Lexend', sans-serif;">
          {heading}
        </h2>
      </div>
      <a
        href={ctaHref}
        class="shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 transition inline-flex items-center gap-2"
        style="font-family: 'Inter', sans-serif;"
      >
        {ctaLabel}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>

    <!-- Review cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reviews.map(({ body, authorName, authorTitle, rating = 5 }) => (
        <div class="flex flex-col gap-5 bg-slate-50 rounded-2xl border border-slate-200 p-6">
          <!-- Stars -->
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg class={`w-4 h-4 ${i < rating ? 'text-amber-400' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-slate-700 leading-relaxed text-sm flex-1" style="font-family: 'Inter', sans-serif;">
            &ldquo;{body}&rdquo;
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-2 border-t border-slate-200">
            <div class="w-9 h-9 rounded-full bg-slate-200 flex items-center justify-center shrink-0">
              <span class="text-xs font-bold text-slate-600" style="font-family: 'Inter', sans-serif;">
                {authorName.charAt(0)}
              </span>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-900" style="font-family: 'Inter', sans-serif;">{authorName}</p>
              {authorTitle && <p class="text-xs text-slate-500" style="font-family: 'Inter', sans-serif;">{authorTitle}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
