---
import {
  STATUS_META,
  PRIORITY_META,
  CATEGORY_LABELS,
  type DevTask,
} from '@lib/devTasks';

interface Props {
  tasks: DevTask[];
}

const { tasks } = Astro.props;
---

{tasks.length === 0 ? (
  <p class="text-sm text-slate-400 py-6 text-center" style="font-family: 'Inter', sans-serif;">No tasks in this view.</p>
) : (
  <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-100 bg-slate-50">
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide w-12" style="font-family: 'Inter', sans-serif;">#</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Task</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide w-28 hidden md:table-cell" style="font-family: 'Inter', sans-serif;">Category</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide w-32" style="font-family: 'Inter', sans-serif;">Priority</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide w-20 hidden lg:table-cell" style="font-family: 'Inter', sans-serif;">Target</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide w-28" style="font-family: 'Inter', sans-serif;">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        {tasks.map((task) => {
          const status = STATUS_META[task.status];
          const priority = PRIORITY_META[task.priority];
          return (
            <tr class="hover:bg-slate-50 transition group">
              <td class="px-4 py-3 text-xs font-mono text-slate-400">{task.id}</td>
              <td class="px-4 py-3">
                <a href={`/admin/dev/${task.id}`} class="group/link">
                  <p class="text-sm font-medium text-slate-800 group-hover/link:text-slate-900 group-hover/link:underline underline-offset-2 leading-snug" style="font-family: 'Inter', sans-serif;">
                    {task.title}
                  </p>
                  <p class="text-xs text-slate-400 mt-0.5 line-clamp-1" style="font-family: 'Inter', sans-serif;">{task.notes}</p>
                </a>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="text-xs text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full whitespace-nowrap" style="font-family: 'Inter', sans-serif;">
                  {CATEGORY_LABELS[task.category]}
                </span>
              </td>
              <td class="px-4 py-3">
                {task.priority !== 'none' ? (
                  <span class={`text-xs font-semibold px-2 py-0.5 rounded-full whitespace-nowrap ${priority.color}`} style="font-family: 'Inter', sans-serif;">
                    {task.priority}
                  </span>
                ) : (
                  <span class="text-xs text-slate-300" style="font-family: 'Inter', sans-serif;">—</span>
                )}
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                {task.version ? (
                  <span class="text-xs font-mono text-slate-400">{task.version}</span>
                ) : (
                  <span class="text-xs text-slate-300">—</span>
                )}
              </td>
              <td class="px-4 py-3">
                <span class={`inline-flex items-center gap-1.5 text-xs font-medium px-2 py-0.5 rounded-full whitespace-nowrap ${status.color}`} style="font-family: 'Inter', sans-serif;">
                  <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${status.dot}`}></span>
                  {status.label}
                </span>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
)}
