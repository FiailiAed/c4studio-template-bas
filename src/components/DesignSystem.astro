---
const brandColors = [
  {
    name: 'Primary', hex: '#0F172A', bg: 'bg-slate-900', light: false,
    shades: ['bg-slate-950','bg-slate-900','bg-slate-800','bg-slate-700','bg-slate-600','bg-slate-500','bg-slate-400','bg-slate-300','bg-slate-200','bg-slate-100','bg-slate-50'],
  },
  {
    name: 'Secondary', hex: '#2563EB', bg: 'bg-blue-600', light: false,
    shades: ['bg-blue-950','bg-blue-900','bg-blue-800','bg-blue-700','bg-blue-600','bg-blue-500','bg-blue-400','bg-blue-300','bg-blue-200','bg-blue-100','bg-blue-50'],
  },
  {
    name: 'Tertiary', hex: '#0EA5E9', bg: 'bg-sky-500', light: false,
    shades: ['bg-sky-950','bg-sky-900','bg-sky-800','bg-sky-700','bg-sky-600','bg-sky-500','bg-sky-400','bg-sky-300','bg-sky-200','bg-sky-100','bg-sky-50'],
  },
  {
    name: 'Neutral', hex: '#F8FAFC', bg: 'bg-white', light: true,
    shades: ['bg-slate-950','bg-slate-900','bg-slate-800','bg-slate-700','bg-slate-600','bg-slate-500','bg-slate-400','bg-slate-300','bg-slate-200','bg-slate-100','bg-slate-50'],
  },
] as const;
---

<div class="w-full">
  <h2 class="text-2xl font-bold tracking-tight mb-2" style="font-family: 'Lexend', sans-serif;">Design System</h2>
  <p class="text-sm text-slate-500 mb-8" style="font-family: 'Inter', sans-serif;">Brand colors, typography, and UI components</p>

  <!-- ── Brand Colors (4 cards in a row) ─────────────────────────── -->
  <div class="grid grid-cols-4 gap-4 mb-4">
    {brandColors.map(({ name, hex, bg, light, shades }) => (
      <div class={`${bg} rounded-2xl overflow-hidden border border-slate-200`}>
        <div class={`flex items-start justify-between px-4 pt-4 pb-12 ${light ? 'text-slate-900' : 'text-white'}`}>
          <span class="text-sm font-semibold" style="font-family: 'Inter', sans-serif;">{name}</span>
          <span class="text-xs font-mono opacity-70">{hex}</span>
        </div>
        <div class="flex">
          {shades.map((cls) => (
            <div class={`${cls} flex-1 h-10`} />
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- ── UI Component Grid (3 columns × 3 rows) ─────────────────── -->
  <div class="grid grid-cols-3 gap-4">

    <!-- Row 1, Col 1 — Headline / Lexend -->
    <div class="bg-white rounded-2xl p-6 flex flex-col justify-between min-h-[180px] border border-slate-100">
      <div class="flex items-center justify-between text-xs text-slate-400">
        <span style="font-family: 'Inter', sans-serif;">Headline</span>
        <span style="font-family: 'Inter', sans-serif;">Lexend</span>
      </div>
      <p class="text-8xl font-bold text-slate-900 leading-none mt-4" style="font-family: 'Lexend', sans-serif;">Aa</p>
    </div>

    <!-- Row 1, Col 2 — Buttons -->
    <div class="bg-white rounded-2xl p-6 flex flex-col justify-center gap-3 min-h-[180px] border border-slate-100">
      <div class="grid grid-cols-2 gap-3">
        <button class="bg-slate-900 text-white text-sm font-semibold px-4 py-2.5 rounded-xl" style="font-family: 'Inter', sans-serif;">Primary</button>
        <button class="bg-slate-100 text-slate-700 text-sm font-semibold px-4 py-2.5 rounded-xl" style="font-family: 'Inter', sans-serif;">Secondary</button>
        <button class="bg-slate-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl" style="font-family: 'Inter', sans-serif;">Inverted</button>
        <button class="border-2 border-slate-900 text-slate-900 text-sm font-semibold px-4 py-2.5 rounded-xl bg-transparent" style="font-family: 'Inter', sans-serif;">Outlined</button>
      </div>
    </div>

    <!-- Row 1, Col 3 — Search bar -->
    <div class="bg-white rounded-2xl p-6 flex flex-col justify-center min-h-[180px] border border-slate-100">
      <div class="flex items-center gap-3 bg-slate-100 rounded-xl px-4 py-3">
        <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
        </svg>
        <span class="text-sm text-slate-400" style="font-family: 'Inter', sans-serif;">Search</span>
      </div>
    </div>

    <!-- Row 2, Col 1 — Body / Inter -->
    <div class="bg-white rounded-2xl p-6 flex flex-col justify-between min-h-[180px] border border-slate-100">
      <div class="flex items-center justify-between text-xs text-slate-400">
        <span style="font-family: 'Inter', sans-serif;">Body</span>
        <span style="font-family: 'Inter', sans-serif;">Inter</span>
      </div>
      <p class="text-8xl text-slate-700 leading-none mt-4" style="font-family: 'Inter', sans-serif;">Aa</p>
    </div>

    <!-- Row 2, Col 2 — Progress bars -->
    <div class="bg-white rounded-2xl p-6 flex flex-col justify-center gap-4 min-h-[180px] border border-slate-100">
      <div class="h-2 bg-slate-900 rounded-full w-full"></div>
      <div class="h-2 bg-blue-600 rounded-full w-4/5"></div>
      <div class="h-2 bg-slate-900 rounded-full w-2/5"></div>
    </div>

    <!-- Row 2, Col 3 — Toolbar / Nav -->
    <div class="bg-white rounded-2xl p-6 flex items-center justify-center gap-5 min-h-[180px] border border-slate-100">
      <button class="bg-slate-900 p-3 rounded-xl">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/>
        </svg>
      </button>
      <button class="text-slate-400 hover:text-slate-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
        </svg>
      </button>
      <button class="text-slate-400 hover:text-slate-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
        </svg>
      </button>
    </div>

    <!-- Row 3, Col 1 — Label / Inter -->
    <div class="bg-white rounded-2xl p-6 flex flex-col justify-between min-h-[180px] border border-slate-100">
      <div class="flex items-center justify-between text-xs text-slate-400">
        <span style="font-family: 'Inter', sans-serif;">Label</span>
        <span style="font-family: 'Inter', sans-serif;">Inter</span>
      </div>
      <p class="text-8xl font-medium text-slate-500 leading-none mt-4" style="font-family: 'Inter', sans-serif;">Aa</p>
    </div>

    <!-- Row 3, Col 2 — Edit buttons -->
    <div class="bg-white rounded-2xl p-6 flex flex-col justify-center gap-4 min-h-[180px] border border-slate-100">
      <div class="flex items-center gap-3">
        <!-- Icon-only -->
        <button class="bg-sky-700 p-3 rounded-xl shrink-0">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125"/>
          </svg>
        </button>
        <!-- Icon + label -->
        <button class="bg-sky-700 flex items-center gap-2 px-4 py-3 rounded-xl">
          <svg class="w-4 h-4 text-white shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125"/>
          </svg>
          <span class="text-white text-sm font-medium whitespace-nowrap" style="font-family: 'Inter', sans-serif;">Label</span>
        </button>
      </div>
    </div>

    <!-- Row 3, Col 3 — Action buttons -->
    <div class="bg-white rounded-2xl p-6 flex items-center justify-center gap-3 min-h-[180px] border border-slate-100">
      <button class="bg-slate-900 p-3 rounded-xl">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
        </svg>
      </button>
      <button class="bg-blue-600 p-3 rounded-xl">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"/>
        </svg>
      </button>
      <button class="bg-slate-200 p-3 rounded-xl">
        <svg class="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L9.568 3z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z"/>
        </svg>
      </button>
      <button class="bg-red-500 p-3 rounded-xl">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
        </svg>
      </button>
    </div>

  </div>
</div>
