---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { enforcePageStatus } from '@lib/pageStatus';

const redirect = await enforcePageStatus('/blog', Astro);
if (redirect) return redirect;

const settings = await convex.query(api.settings.get, {});
if (settings?.blogEnabled === false) return Astro.redirect('/404');

const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

const post = await convex.query(api.posts.getBySlug, { slug });
if (!post || !post.published) return Astro.redirect('/404');

const publishedDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : null;
---

<BaseLayout
  title={`${post.title} — ${appName}`}
  description={post.excerpt ?? `Read ${post.title} on the ${appName} blog.`}
>
  <Header slot="header" appName={appName} />

  <!-- Article header -->
  <section class="bg-slate-900 text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-600/10 blur-3xl pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto px-6">
      <a href="/blog" class="inline-flex items-center gap-2 text-xs font-semibold text-slate-400 hover:text-white transition uppercase tracking-widest mb-8" style="font-family: 'Inter', sans-serif;">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        Blog
      </a>

      {post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {post.tags.map((tag) => (
            <span class="text-xs font-medium text-slate-400 bg-white/10 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">{tag}</span>
          ))}
        </div>
      )}

      <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] mb-6" style="font-family: 'Lexend', sans-serif;">
        {post.title}
      </h1>

      {post.excerpt && (
        <p class="text-lg text-slate-400 leading-relaxed mb-8" style="font-family: 'Inter', sans-serif;">{post.excerpt}</p>
      )}

      <div class="flex items-center gap-3 text-sm text-slate-400" style="font-family: 'Inter', sans-serif;">
        <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center shrink-0">
          <span class="text-xs font-bold text-slate-300">{post.authorName.charAt(0)}</span>
        </div>
        <span>{post.authorName}</span>
        {publishedDate && (
          <>
            <span class="w-1 h-1 rounded-full bg-slate-600"></span>
            <span>{publishedDate}</span>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- Article body -->
  <section class="bg-white py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-6">
      <div
        class="prose prose-slate prose-lg max-w-none
          prose-headings:font-bold prose-headings:tracking-tight
          prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:leading-relaxed prose-p:text-slate-600
          prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
          prose-strong:text-slate-900
          prose-blockquote:border-l-4 prose-blockquote:border-slate-200 prose-blockquote:pl-4 prose-blockquote:text-slate-500 prose-blockquote:not-italic
          prose-code:bg-slate-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-code:before:content-none prose-code:after:content-none
          prose-pre:bg-slate-900 prose-pre:text-slate-100 prose-pre:rounded-2xl
          prose-ul:text-slate-600 prose-ol:text-slate-600
          prose-li:my-1
          prose-img:rounded-2xl"
        set:html={post.body}
      />
    </div>
  </section>

  <!-- Back to blog -->
  <section class="bg-slate-50 py-12 border-t border-slate-100">
    <div class="max-w-3xl mx-auto px-6">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-slate-900 transition"
        style="font-family: 'Inter', sans-serif;"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        Back to all posts
      </a>
    </div>
  </section>

  <CTA
    heading={"Ready to work\ntogether?"}
    subheading="Tell us about your project. We'll get back to you within one business day."
    primaryCta={{ label: 'Get in touch', href: '/contact' }}
    secondaryCta={{ label: 'See our services', href: '/services' }}
  />

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
