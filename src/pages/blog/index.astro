---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { enforcePageStatus } from '@lib/pageStatus';

const redirect = await enforcePageStatus('/blog', Astro);
if (redirect) return redirect;

const settings = await convex.query(api.settings.get, {});
if (settings?.blogEnabled === false) return Astro.redirect('/404');

const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const posts = await convex.query(api.posts.listPublished, {});
---

<BaseLayout
  title={`Blog — ${appName}`}
  description={`Insights, ideas, and updates from the ${appName} team.`}
>
  <Header slot="header" appName={appName} />

  <!-- Hero -->
  <section class="bg-slate-900 text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-emerald-600/10 blur-3xl pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto px-6">
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-emerald-400 uppercase tracking-widest mb-6" style="font-family: 'Inter', sans-serif;">
        <span class="w-6 h-px bg-emerald-400"></span>
        Blog
      </p>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight leading-[1.05] mb-6" style="font-family: 'Lexend', sans-serif;">
        Ideas worth<br />reading.
      </h1>
      <p class="text-lg text-slate-400 leading-relaxed max-w-xl" style="font-family: 'Inter', sans-serif;">
        Insights, strategy, and lessons from the work we do.
      </p>
    </div>
  </section>

  <!-- Post list -->
  <section class="bg-white py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      {posts.length === 0 ? (
        <div class="text-center py-24">
          <p class="text-slate-400 text-sm" style="font-family: 'Inter', sans-serif;">No posts yet — check back soon.</p>
        </div>
      ) : (
        <div class="flex flex-col divide-y divide-slate-100">
          {posts.map((post) => {
            const date = post.publishedAt
              ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
              : null;
            return (
              <article class="py-10 first:pt-0 last:pb-0 group">
                <a href={`/blog/${post.slug}`} class="block">
                  <div class="flex items-start justify-between gap-8">
                    <div class="flex-1 min-w-0">
                      {post.tags.length > 0 && (
                        <div class="flex flex-wrap gap-2 mb-3">
                          {post.tags.map((tag) => (
                            <span class="text-xs font-medium text-slate-500 bg-slate-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">{tag}</span>
                          ))}
                        </div>
                      )}
                      <h2 class="text-2xl font-bold text-slate-900 group-hover:text-blue-600 transition leading-snug mb-3" style="font-family: 'Lexend', sans-serif;">
                        {post.title}
                      </h2>
                      {post.excerpt && (
                        <p class="text-slate-500 leading-relaxed line-clamp-3 mb-4" style="font-family: 'Inter', sans-serif;">{post.excerpt}</p>
                      )}
                      <div class="flex items-center gap-3 text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">
                        <span>{post.authorName}</span>
                        {date && (
                          <>
                            <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                            <span>{date}</span>
                          </>
                        )}
                      </div>
                    </div>
                    <div class="shrink-0 mt-1">
                      <svg class="w-5 h-5 text-slate-300 group-hover:text-blue-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                      </svg>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CTA
    heading={"Have a project\nin mind?"}
    subheading="Tell us about it. We'll get back to you within one business day."
    primaryCta={{ label: 'Get in touch', href: '/contact' }}
    secondaryCta={{ label: 'See our services', href: '/services' }}
  />

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
