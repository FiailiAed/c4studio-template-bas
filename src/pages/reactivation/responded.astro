---
import BaseLayout from '@layouts/BaseLayout.astro';

const r = Astro.url.searchParams.get('r');
const error = Astro.url.searchParams.get('error');

const content = error
  ? { title: 'Something went wrong', body: 'This link may have expired or already been used. If you need help, reply to the original email.', icon: '⚠️', iconBg: 'bg-amber-50 border-amber-100', iconText: 'text-amber-600' }
  : r === 'yes'
  ? { title: "You're in!", body: "We've received your response and you're entered. We'll be in touch shortly — check your email for a confirmation and a booking link.", icon: '✓', iconBg: 'bg-emerald-50 border-emerald-100', iconText: 'text-emerald-600' }
  : { title: "You've been removed", body: "No problem at all — you won't receive any further messages about this offer. If you ever want to reconnect, just reach out.", icon: '✓', iconBg: 'bg-slate-50 border-slate-200', iconText: 'text-slate-400' };
---

<BaseLayout title={content.title}>
  <div class="min-h-screen bg-slate-50 flex items-center justify-center px-4 py-16">
    <div class="max-w-sm w-full bg-white rounded-2xl border border-slate-200 px-8 py-12 text-center">
      <div class={`w-14 h-14 rounded-full border flex items-center justify-center mx-auto mb-6 ${content.iconBg}`}>
        <span class={`text-2xl font-bold ${content.iconText}`}>{content.icon}</span>
      </div>
      <h1 class="text-xl font-bold text-slate-900 mb-3" style="font-family: 'Lexend', sans-serif;">{content.title}</h1>
      <p class="text-sm text-slate-500 leading-relaxed" style="font-family: 'Inter', sans-serif;">{content.body}</p>
    </div>
  </div>
</BaseLayout>
