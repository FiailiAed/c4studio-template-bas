---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import Hero from '@marketing/Hero.astro';
import TrustBar from '@marketing/TrustBar.astro';
import Services from '@marketing/Services.astro';
import About from '@marketing/About.astro';
import Reviews from '@marketing/Reviews.astro';
import Gallery from '@marketing/Gallery.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { enforcePageStatus } from '@lib/pageStatus';

const redirect = await enforcePageStatus('/', Astro);
if (redirect) return redirect;

const [settings, galleryItems] = await Promise.all([
  convex.query(api.settings.get, {}),
  convex.query(api.gallery.listPublishedWithUrls, {}),
]);

const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const galleryImages = galleryItems
  .filter((item) => item.mediaType === 'image' && item.url)
  .slice(0, 6)
  .map((item) => ({
    src: item.url as string,
    alt: item.title ?? 'Gallery image',
    width: item.width,
    height: item.height,
  }));
---

<BaseLayout
  title={`${appName} — Home`}
  description={description}
>
  <Header slot="header" appName={appName} />

  <Hero
    subheadline={description}
  />
  <TrustBar />
  <Services />
  <About />
  <Reviews />
  <Gallery items={galleryImages} />
  <CTA />

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
