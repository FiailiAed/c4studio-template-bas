---
import BaseLayout from '@layouts/BaseLayout.astro';
import TailwindColorGrid from '@components/TailwindColorGrid.astro';
import TechStack from '@components/TechStack.astro';
import DesignSystem from '@components/DesignSystem.astro';
---

<BaseLayout title="c4studio BAS">
  <div class="min-h-screen py-16 px-8 bg-slate-50">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900" style="font-family: 'Lexend', sans-serif;">c4studio-template-bas</h1>
      <p class="mt-3 text-lg text-slate-500" style="font-family: 'Inter', sans-serif;">Basic Astro Setup Template for c4studio</p>
    </div>

    <div class="flex flex-col gap-16">
      <!-- Row 1: Color grid + Tech stack -->
      <div class="flex gap-12 items-start">
        <TailwindColorGrid />
        <TechStack />
      </div>

      <!-- Row 2: Full-width design system -->
      <DesignSystem />
    </div>
  </div>
</BaseLayout>
