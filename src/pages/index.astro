---
import BaseLayout from '@layouts/BaseLayout.astro';
import TailwindColorGrid from '@components/TailwindColorGrid.astro';
---

<BaseLayout title="c4studio BAS">
  <div class="min-h-screen py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-bold tracking-tight">c4studio-template-bas</h1>
        <p class="mt-3 text-lg text-gray-500">Basic Astro Setup Template for c4studio</p>
      </div>
      <TailwindColorGrid />
    </div>
  </div>
</BaseLayout>
