---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { enforcePageStatus } from '@lib/pageStatus';

const redirect = await enforcePageStatus('/gallery', Astro);
if (redirect) return redirect;

const [items, settings] = await Promise.all([
  convex.query(api.gallery.listPublishedWithUrls, {}),
  convex.query(api.settings.get, {}),
]);

const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';
---

<BaseLayout title={`Gallery — ${appName}`} description="Our work and media gallery.">
  <Header slot="header" appName={appName} />

  <!-- Hero -->
  <section class="bg-slate-900 pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-blue-400 uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">
        <span class="w-6 h-px bg-blue-400"></span>
        Our work
      </p>
      <h1 class="text-5xl md:text-6xl font-bold text-white tracking-tight leading-tight" style="font-family: 'Lexend', sans-serif;">
        Built to<br />be seen.
      </h1>
      <p class="text-slate-400 mt-4 max-w-xl text-lg" style="font-family: 'Inter', sans-serif;">
        A look at projects, designs, and work we're proud of.
      </p>
    </div>
  </section>

  <!-- Gallery -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-6xl mx-auto px-6">
      {items.length === 0 ? (
        <div class="py-20 text-center">
          <div class="w-16 h-16 rounded-full bg-slate-200 flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
            </svg>
          </div>
          <p class="text-lg font-semibold text-slate-600" style="font-family: 'Lexend', sans-serif;">Nothing published yet.</p>
          <p class="text-sm text-slate-400 mt-2" style="font-family: 'Inter', sans-serif;">Check back soon — we're building something worth showing.</p>
        </div>
      ) : (
        <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
          {items.map((item) => (
            <div class="break-inside-avoid group">
              {item.mediaType === 'image' && item.url && (
                <div class="rounded-2xl overflow-hidden bg-slate-200">
                  <img
                    src={item.url}
                    alt={item.title ?? 'Gallery image'}
                    width={item.width}
                    height={item.height}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-auto block group-hover:scale-[1.02] transition duration-500"
                  />
                  {(item.title || item.description) && (
                    <div class="p-4">
                      {item.title && <p class="text-sm font-semibold text-slate-900" style="font-family: 'Inter', sans-serif;">{item.title}</p>}
                      {item.description && <p class="text-xs text-slate-500 mt-0.5" style="font-family: 'Inter', sans-serif;">{item.description}</p>}
                    </div>
                  )}
                </div>
              )}

              {item.mediaType === 'video' && item.url && (
                <div class="rounded-2xl overflow-hidden bg-slate-900">
                  <video
                    src={item.url}
                    controls
                    preload="metadata"
                    class="w-full h-auto block"
                  />
                  {(item.title || item.description) && (
                    <div class="p-4">
                      {item.title && <p class="text-sm font-semibold text-white" style="font-family: 'Inter', sans-serif;">{item.title}</p>}
                      {item.description && <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">{item.description}</p>}
                    </div>
                  )}
                </div>
              )}

              {item.mediaType === 'pdf' && item.url && (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-5 hover:shadow-md transition group/pdf"
                >
                  <div class="w-12 h-12 rounded-xl bg-red-100 flex items-center justify-center shrink-0">
                    <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
                    </svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-semibold text-slate-900 group-hover/pdf:underline truncate" style="font-family: 'Inter', sans-serif;">
                      {item.title ?? 'Download PDF'}
                    </p>
                    {item.description && (
                      <p class="text-xs text-slate-500 truncate mt-0.5" style="font-family: 'Inter', sans-serif;">{item.description}</p>
                    )}
                    <p class="text-xs text-slate-400 mt-0.5 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">PDF ↗</p>
                  </div>
                </a>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <CTA />
  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
