---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignUp } from '@clerk/astro/components';
import { convex } from '@lib/convex';
import { api } from '@convex/api';

const { userId } = Astro.locals.auth();
if (userId) return Astro.redirect('/dashboard');

const settings = await convex.query(api.settings.get, {});
if (settings?.registrationEnabled === false) return Astro.redirect('/');
---

<BaseLayout title="Sign Up — c4studio BAS">
  <div class="min-h-screen flex items-center justify-center bg-slate-50 py-16 px-4">
    <SignUp />
  </div>
</BaseLayout>
