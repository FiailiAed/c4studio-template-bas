---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

let successMessage: string | null = null;
let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action') as string;

  try {
    if (action === 'create') {
      const name = (data.get('name') as string).trim();
      const slug = (data.get('slug') as string).trim();
      if (!name || !slug) throw new Error('Name and slug are required.');
      await client.mutation(api.bookingLinks.create, {
        name,
        slug,
        description: (data.get('description') as string).trim() || undefined,
        published: data.get('published') === 'on',
      });
      successMessage = `Booking link "${name}" created.`;
    }
  } catch (e) {
    errorMessage = e instanceof Error ? e.message : 'Action failed.';
  }
}

const bookingLinks = await client.query(api.bookingLinks.list, {});
---

<BaseLayout title="Booking Links — Admin Portal">
  <div class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Booking Links</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-slate-900" style="font-family: 'Lexend', sans-serif;">Booking Links</h1>
          <p class="text-slate-500 mt-1" style="font-family: 'Inter', sans-serif;">{bookingLinks.length} {bookingLinks.length === 1 ? 'link' : 'links'}</p>
        </div>
        <button
          onclick="document.getElementById('create-form').classList.toggle('hidden')"
          class="text-sm font-semibold bg-slate-900 text-white px-4 py-2.5 rounded-xl hover:bg-slate-700 transition"
          style="font-family: 'Inter', sans-serif;"
        >
          + New link
        </button>
      </div>

      {successMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-700" style="font-family: 'Inter', sans-serif;">{successMessage}</div>
      )}
      {errorMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700" style="font-family: 'Inter', sans-serif;">{errorMessage}</div>
      )}

      <!-- Create form -->
      <div id="create-form" class={`bg-white rounded-2xl border border-slate-200 p-6 mb-6 ${successMessage ? '' : 'hidden'}`}>
        <h2 class="text-base font-semibold text-slate-900 mb-5" style="font-family: 'Lexend', sans-serif;">New booking link</h2>
        <form method="POST" class="flex flex-col gap-4">
          <input type="hidden" name="action" value="create" />
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Name <span class="text-red-500">*</span></label>
              <input id="link-name" type="text" name="name" required placeholder="30-Min Intro Call"
                class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900"
                style="font-family: 'Inter', sans-serif;" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Slug <span class="text-red-500">*</span></label>
              <input id="link-slug" type="text" name="slug" required placeholder="30-min-intro"
                class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 font-mono"
                style="font-family: 'Inter', sans-serif;" />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Description</label>
            <input type="text" name="description" placeholder="Optional short description"
              class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900"
              style="font-family: 'Inter', sans-serif;" />
          </div>
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="published" value="on" class="w-4 h-4 rounded" />
              <span class="text-sm text-slate-700" style="font-family: 'Inter', sans-serif;">Publish immediately</span>
            </label>
            <button type="submit" class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition" style="font-family: 'Inter', sans-serif;">
              Create link
            </button>
          </div>
        </form>
      </div>

      <!-- List -->
      {bookingLinks.length === 0 ? (
        <div class="bg-white rounded-2xl border border-slate-200 p-16 text-center">
          <p class="text-slate-400 text-sm mb-4" style="font-family: 'Inter', sans-serif;">No booking links yet.</p>
          <button onclick="document.getElementById('create-form').classList.remove('hidden'); document.getElementById('link-name').focus()"
            class="text-sm font-semibold text-slate-600 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">
            Create your first booking link →
          </button>
        </div>
      ) : (
        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-100 bg-slate-50">
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Name</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Slug</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Status</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Created</th>
                <th class="px-5 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {bookingLinks.map((l) => (
                <tr class="hover:bg-slate-50 transition">
                  <td class="px-5 py-4">
                    <p class="font-medium text-slate-900" style="font-family: 'Inter', sans-serif;">{l.name}</p>
                    {l.description && <p class="text-xs text-slate-400 mt-0.5 truncate max-w-xs">{l.description}</p>}
                  </td>
                  <td class="px-5 py-4">
                    <span class="text-xs font-mono text-slate-500 bg-slate-100 px-2 py-1 rounded-lg">{l.slug}</span>
                  </td>
                  <td class="px-5 py-4">
                    {l.published ? (
                      <span class="inline-flex items-center gap-1 text-xs font-medium text-emerald-600 bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                        published
                      </span>
                    ) : (
                      <span class="text-xs font-medium text-slate-400 bg-slate-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">draft</span>
                    )}
                  </td>
                  <td class="px-5 py-4 text-slate-500 text-xs" style="font-family: 'Inter', sans-serif;">
                    {new Date(l._creationTime).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </td>
                  <td class="px-5 py-4 text-right">
                    <a href={`/admin/booking-links/${l._id}`}
                      class="text-xs font-medium text-slate-600 hover:text-slate-900 bg-slate-100 hover:bg-slate-200 px-3 py-1.5 rounded-lg transition"
                      style="font-family: 'Inter', sans-serif;">
                      Edit
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </main>
  </div>
</BaseLayout>

<script>
  const nameInput = document.getElementById('link-name') as HTMLInputElement | null;
  const slugInput = document.getElementById('link-slug') as HTMLInputElement | null;
  nameInput?.addEventListener('input', () => {
    if (slugInput && !slugInput.dataset.edited) {
      slugInput.value = nameInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }
  });
  slugInput?.addEventListener('input', () => { if (slugInput.value) slugInput.dataset.edited = 'true'; else delete slugInput.dataset.edited; });
</script>
