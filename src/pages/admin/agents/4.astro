      <!-- ── Test tab ─────────────────────────────────────────────── -->
      <div id="tab-test" class={`tab-panel ${activeTab !== 'test' ? 'hidden' : ''}`}>

        <!-- Setup card -->
        <div id="test-setup-4" class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-6">
          <div class="px-6 py-4 border-b border-slate-100">
            <h2 class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Test Setup</h2>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">Real emails will be sent via Resend and logged with <code class="bg-slate-100 px-1 rounded">isTest: true</code> in History. R5 templates are copy-paste only — not testable here.</p>
          </div>
