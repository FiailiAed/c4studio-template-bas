---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';
import { getAgent } from '@lib/agents';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

const existingMessages = await client.query(api.reviews.listMessages, {});
if (existingMessages.length === 0) await client.mutation(api.reviews.initializeDefaults, {});

let successMessage: string | null = Astro.url.searchParams.get('success')
  ? 'Changes saved.' : null;
let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action') as string;
  try {
    if (action === 'update-message') {
      const messageKey = (data.get('messageKey') as string).trim();
      const channel = data.get('channel') as 'email' | 'sms' | 'both';
      if (!['email', 'sms', 'both'].includes(channel)) throw new Error('Invalid channel.');
      await client.mutation(api.reviews.upsertMessage, {
        messageKey,
        enabled: data.get('enabled') === 'on',
        channel,
        smsBody: (data.get('smsBody') as string ?? '').trim(),
        emailSubject: (data.get('emailSubject') as string ?? '').trim(),
        emailBody: (data.get('emailBody') as string ?? '').trim(),
      });
      return Astro.redirect('/admin/agents/4?tab=messages&success=1');
    }
    if (action === 'manual-trigger') {
      const bookingEmail = (data.get('bookingEmail') as string).trim().toLowerCase();
      const messageKey = (data.get('messageKey') as string).trim();
      if (!bookingEmail || !messageKey) throw new Error('Email and message are required.');
      const booking = await client.query(api.bookings.getLatestByEmail, { email: bookingEmail });
      if (!booking) throw new Error(`No booking found for "${bookingEmail}".`);
      await client.mutation(api.reviews.triggerMessageForBooking, {
        bookingId: booking._id,
        messageKey,
      });
      return Astro.redirect('/admin/agents/4?tab=messages&success=1');
    }
  } catch (e) {
    errorMessage = e instanceof Error ? e.message : 'Action failed.';
  }
}

const activeTab = Astro.url.searchParams.get('tab') ?? 'messages';
const [messages, stats, recentLogs, settings] = await Promise.all([
  client.query(api.reviews.listMessages, {}),
  client.query(api.reviews.getStats, {}),
  client.query(api.reviews.listLogs, { limit: 100 }),
  client.query(api.settings.get, {}),
]);

const automatedMessages = messages.filter(m => m.messageType === 'automated').sort((a, b) => a.order - b.order);
const templateMessages = messages.filter(m => m.messageType === 'template').sort((a, b) => a.order - b.order);

const agent = getAgent(4)!;
const agentData = {
  longPrompt: agent.long.prompt,
  shortPrompt: agent.short.prompt,
  longVars: agent.long.variables,
  shortVars: agent.short.variables,
  longNote: agent.long.note ?? null,
  shortNote: agent.short.note ?? null,
};

const MSG_LABELS: Record<string, string> = {
  r1: 'R1', r2: 'R2', r3: 'R3', r4: 'R4',
  r5a: 'R5a', r5b: 'R5b', r5c: 'R5c', r5d: 'R5d', r5e: 'R5e',
};

const [rawBookings, rawBookingLinks] = await Promise.all([
  client.query(api.bookings.listAll, {}),
  client.query(api.bookingLinks.list, {}),
]);
const linkNameMap: Record<string, string> = {};
rawBookingLinks.forEach((l: { _id: string; name: string }) => { linkNameMap[l._id] = l.name; });
const testBookings = rawBookings.slice(0, 50).map((b: { _id: string; name: string; email: string; phone?: string; date: string; startTime: string; bookingLinkId: string }) => ({
  id: b._id as string,
  name: b.name,
  email: b.email,
  date: b.date,
  startTime: b.startTime,
  linkName: linkNameMap[b.bookingLinkId] ?? 'your session',
}));
const testMessages = messages.filter(m => m.messageType === 'automated').sort((a, b) => a.order - b.order);
const testMsgLabels: Record<string, string> = { r1: 'R1', r2: 'R2', r3: 'R3', r4: 'R4' };
const testSettings = {
  appName: settings?.appName ?? '',
  rafflePrize: settings?.rafflePrize ?? '',
  googleReviewUrl: settings?.googleReviewUrl ?? '',
  feedbackFormLink: settings?.feedbackFormLink ?? '',
  referralShareLink: settings?.referralShareLink ?? '',
  referralIntroOffer: settings?.referralIntroOffer ?? '',
};

function relativeTime(ts: number) {
  const diff = Date.now() - ts;
  if (diff < 60_000) return 'just now';
  if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;
  if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`;
  return `${Math.floor(diff / 86_400_000)}d ago`;
}
---

<BaseLayout title="Reviews & Referrals — Agents">
  <div class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition shrink-0" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300 shrink-0">/</span>
        <a href="/admin/agents" class="text-sm text-slate-500 hover:text-slate-900 transition shrink-0" style="font-family: 'Inter', sans-serif;">Agents</a>
        <span class="text-slate-300 shrink-0">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Reviews & Referrals</span>
      </div>
      <div class="flex items-center gap-4 shrink-0">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-10">
      <div class="flex items-start gap-4 mb-6">
        <div class="shrink-0 w-12 h-12 rounded-2xl bg-white border-2 border-violet-400 flex items-center justify-center">
          <span class="text-lg font-bold text-slate-700" style="font-family: 'Lexend', sans-serif;">4</span>
        </div>
        <div>
          <div class="flex items-center gap-3 mb-1">
            <h1 class="text-2xl font-bold tracking-tight text-slate-900" style="font-family: 'Lexend', sans-serif;">Reviews & Referrals</h1>
            <span class="text-xs font-semibold text-slate-500 bg-slate-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">Day 4</span>
            <span class="text-xs font-semibold text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">Active</span>
          </div>
          <p class="text-sm text-slate-500" style="font-family: 'Inter', sans-serif;">{agent.description}</p>
        </div>
      </div>

      {successMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-700" style="font-family: 'Inter', sans-serif;">{successMessage}</div>
      )}
      {errorMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700" style="font-family: 'Inter', sans-serif;">{errorMessage}</div>
      )}

      <!-- Tabs -->
      <div class="flex items-center gap-1 mb-8 bg-slate-100 rounded-xl p-1 w-fit">
        {(['messages', 'history', 'test', 'settings'] as const).map((tab) => (
          <button data-tab={tab}
            class={`tab-btn text-sm font-medium px-4 py-2 rounded-lg transition capitalize ${activeTab === tab ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'}`}
            style="font-family: 'Inter', sans-serif;">
            {tab === 'settings' ? 'Prompt' : tab === 'test' ? 'Test' : tab.charAt(0).toUpperCase() + tab.slice(1)}
          </button>
        ))}
      </div>

      <!-- ── Messages tab ───────────────────────────────────────── -->
      <div id="tab-messages" class={`tab-panel ${activeTab !== 'messages' ? 'hidden' : ''}`}>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
          <div class="bg-white rounded-2xl border border-slate-200 px-5 py-4">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">Rating requests</p>
            <p class="text-2xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{recentLogs.filter(l => l.messageKey === 'r1').length}</p>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">R1 triggers</p>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 px-5 py-4">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">5-star responses</p>
            <p class="text-2xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{recentLogs.filter(l => l.messageKey === 'r2' && l.status === 'sent').length}</p>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">R2 sent</p>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 px-5 py-4">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">Referral asks</p>
            <p class="text-2xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{recentLogs.filter(l => l.messageKey === 'r4' && l.status === 'sent').length}</p>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">R4 sent</p>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 px-5 py-4">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">Messages active</p>
            <p class="text-2xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{automatedMessages.filter(m => m.enabled).length}<span class="text-sm text-slate-400 font-normal"> / {automatedMessages.length}</span></p>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">automated</p>
          </div>
        </div>

        <!-- Info note -->
        <div class="flex items-start gap-3 bg-blue-50 border border-blue-200 rounded-2xl px-5 py-4 mb-6">
          <svg class="w-4 h-4 text-blue-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"/>
          </svg>
          <div class="text-sm text-blue-800" style="font-family: 'Inter', sans-serif;">
            <strong>R1</strong> fires automatically 2 hours after a booking appointment, or manually via the trigger below. <strong>R2 and R3</strong> require the customer to reply with a rating (inbound SMS/email — Twilio pending). <strong>R4</strong> fires after a confirmed Google review — use the manual trigger. <strong>R5 templates</strong> are copy-paste replies for Google reviews.
          </div>
        </div>

        <!-- Automated messages -->
        <h2 class="text-base font-semibold text-slate-900 mb-3" style="font-family: 'Lexend', sans-serif;">Automated Messages</h2>
        <div class="flex flex-col gap-3 mb-8">
          {automatedMessages.map((msg) => {
            const s = stats[msg.messageKey] ?? { sent: 0, failed: 0, skipped: 0, lastSent: null };
            return (
              <details class="group bg-white rounded-2xl border border-slate-200 overflow-hidden">
                <summary class="flex items-center gap-4 px-6 py-4 cursor-pointer list-none hover:bg-slate-50 transition">
                  <span class="shrink-0 w-10 h-10 rounded-xl bg-violet-50 border border-violet-100 flex items-center justify-center text-xs font-bold text-violet-700" style="font-family: 'Lexend', sans-serif;">
                    {MSG_LABELS[msg.messageKey]}
                  </span>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-slate-900" style="font-family: 'Inter', sans-serif;">{msg.label}</p>
                    <p class="text-xs text-slate-400 truncate" style="font-family: 'Inter', sans-serif;">{msg.triggerDescription}</p>
                  </div>
                  <div class="hidden sm:flex items-center gap-4 shrink-0">
                    <div class="text-right">
                      <p class="text-sm font-semibold text-slate-700" style="font-family: 'Lexend', sans-serif;">{s.sent}</p>
                      <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">sent</p>
                    </div>
                    <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${msg.channel === 'email' ? 'bg-blue-50 text-blue-600 border border-blue-100' : msg.channel === 'sms' ? 'bg-violet-50 text-violet-600 border border-violet-100' : 'bg-emerald-50 text-emerald-600 border border-emerald-100'}`} style="font-family: 'Inter', sans-serif;">{msg.channel}</span>
                    <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${msg.enabled ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' : 'bg-slate-100 text-slate-400'}`} style="font-family: 'Inter', sans-serif;">{msg.enabled ? 'on' : 'off'}</span>
                  </div>
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
                  </svg>
                </summary>
                <div class="border-t border-slate-100 px-6 py-6 bg-slate-50">
                  <form method="POST" class="flex flex-col gap-5">
                    <input type="hidden" name="action" value="update-message" />
                    <input type="hidden" name="messageKey" value={msg.messageKey} />
                    <div class="flex flex-wrap items-center gap-6">
                      <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="enabled" value="on" checked={msg.enabled} class="w-4 h-4 rounded" />
                        <span class="text-sm font-medium text-slate-700" style="font-family: 'Inter', sans-serif;">Enabled</span>
                      </label>
                      <div class="flex items-center gap-3">
                        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Channel</span>
                        {(['email', 'sms', 'both'] as const).map((ch) => (
                          <label class="flex items-center gap-1.5 cursor-pointer">
                            <input type="radio" name="channel" value={ch} checked={msg.channel === ch} class="w-4 h-4" />
                            <span class="text-sm text-slate-700 capitalize" style="font-family: 'Inter', sans-serif;">{ch}</span>
                          </label>
                        ))}
                      </div>
                    </div>
                    <div class="flex flex-col gap-1.5">
                      <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">SMS Body <span class="normal-case font-normal text-slate-400">(≤160 chars)</span></label>
                      <textarea name="smsBody" rows="2" class="text-sm bg-white border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 resize-none font-mono">{msg.smsBody}</textarea>
                    </div>
                    <div class="flex flex-col gap-1.5">
                      <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Email Subject</label>
                      <input type="text" name="emailSubject" value={msg.emailSubject} class="text-sm bg-white border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900" style="font-family: 'Inter', sans-serif;" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                      <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Email Body</label>
                      <textarea name="emailBody" rows="5" class="text-sm bg-white border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 resize-y" style="font-family: 'Inter', sans-serif;">{msg.emailBody}</textarea>
                      <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">
                        Variables: <code class="bg-slate-200 px-1 rounded">{'{{FIRST_NAME}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{SERVICE}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{BUSINESS_NAME}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{RAFFLE_PRIZE}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{GOOGLE_REVIEW_LINK}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{FEEDBACK_FORM_LINK}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{REFERRAL_SHARE_LINK}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{REFERRAL_INTRO_OFFER}}'}</code>
                      </p>
                    </div>
                    <div class="flex justify-end">
                      <button type="submit" class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition" style="font-family: 'Inter', sans-serif;">Save message</button>
                    </div>
                  </form>
                </div>
              </details>
            );
          })}
        </div>

        <!-- Manual trigger for R2/R3/R4 -->
        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-8">
          <div class="px-6 py-5 border-b border-slate-100">
            <h2 class="text-base font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Manual Trigger</h2>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">Send any message manually for a specific customer. Use R1 to trigger a rating request on demand; R4 after a confirmed Google review.</p>
          </div>
          <div class="px-6 py-6">
            <form method="POST" class="flex flex-wrap gap-3 items-end max-w-2xl">
              <input type="hidden" name="action" value="manual-trigger" />
              <div class="flex flex-col gap-1.5 flex-1 min-w-[200px]">
                <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Customer Email</label>
                <input type="email" name="bookingEmail" required placeholder="customer@example.com"
                  class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900"
                  style="font-family: 'Inter', sans-serif;" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Message</label>
                <select name="messageKey" required
                  class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900"
                  style="font-family: 'Inter', sans-serif;">
                  <option value="r1">R1 — Rating Request</option>
                  <option value="r2">R2 — 5-Star Response</option>
                  <option value="r3">R3 — 1–3 Star Response</option>
                  <option value="r4">R4 — Referral Ask</option>
                </select>
              </div>
              <button type="submit"
                class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition shrink-0"
                style="font-family: 'Inter', sans-serif;">
                Send Now
              </button>
            </form>
            <p class="text-xs text-slate-400 mt-3" style="font-family: 'Inter', sans-serif;">Looks up the most recent booking for the email address and sends the selected message immediately.</p>
          </div>
        </div>

        <!-- R5 copy templates -->
        <h2 class="text-base font-semibold text-slate-900 mb-3" style="font-family: 'Lexend', sans-serif;">Google Review Reply Templates</h2>
        <p class="text-sm text-slate-500 mb-4" style="font-family: 'Inter', sans-serif;">Copy these replies and post them manually to 5-star Google reviews. Vary the order and space them out to avoid looking templated.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {templateMessages.map((msg) => (
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
              <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100 bg-slate-50">
                <div class="flex items-center gap-2">
                  <span class="text-xs font-bold text-violet-700 bg-violet-50 px-2 py-0.5 rounded-full" style="font-family: 'Lexend', sans-serif;">{MSG_LABELS[msg.messageKey]}</span>
                  <span class="text-xs text-slate-500" style="font-family: 'Inter', sans-serif;">{msg.label}</span>
                </div>
                <button
                  data-copy-text={msg.emailBody}
                  class="copy-template-btn text-xs font-medium text-slate-500 hover:text-slate-900 transition"
                  style="font-family: 'Inter', sans-serif;">
                  Copy
                </button>
              </div>
              <div class="px-4 py-4">
                <p class="text-sm text-slate-600 leading-relaxed" style="font-family: 'Inter', sans-serif;">{msg.emailBody}</p>
              </div>
              <!-- Edit form (inline) -->
              <details class="border-t border-slate-100">
                <summary class="px-4 py-2 text-xs font-medium text-slate-400 hover:text-slate-600 cursor-pointer list-none" style="font-family: 'Inter', sans-serif;">Edit template ›</summary>
                <div class="px-4 py-4 bg-slate-50">
                  <form method="POST" class="flex flex-col gap-3">
                    <input type="hidden" name="action" value="update-message" />
                    <input type="hidden" name="messageKey" value={msg.messageKey} />
                    <input type="hidden" name="enabled" value="on" />
                    <input type="hidden" name="channel" value="email" />
                    <input type="hidden" name="smsBody" value="" />
                    <input type="hidden" name="emailSubject" value="" />
                    <textarea name="emailBody" rows="3"
                      class="text-sm bg-white border border-slate-200 rounded-xl px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 resize-none"
                      style="font-family: 'Inter', sans-serif;">{msg.emailBody}</textarea>
                    <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">Variable: <code class="bg-slate-200 px-1 rounded">{'{{CUSTOMER_FIRST_NAME}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{BUSINESS_NAME}}'}</code></p>
                    <div class="flex justify-end">
                      <button type="submit" class="text-xs font-semibold bg-slate-900 text-white px-3 py-1.5 rounded-lg hover:bg-slate-700 transition" style="font-family: 'Inter', sans-serif;">Save</button>
                    </div>
                  </form>
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>

      <!-- ── History tab ────────────────────────────────────────── -->
      <div id="tab-history" class={`tab-panel ${activeTab !== 'history' ? 'hidden' : ''}`}>
        <section class="mb-8">
          <h2 class="text-base font-semibold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">Per-Message Stats</h2>
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-slate-100 bg-slate-50">
                  {['Message', 'Type', 'Sent', 'Failed', 'Skipped', 'Last Sent'].map(h => (
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {automatedMessages.map((msg) => {
                  const s = stats[msg.messageKey] ?? { sent: 0, failed: 0, skipped: 0, lastSent: null };
                  return (
                    <tr class="hover:bg-slate-50 transition">
                      <td class="px-5 py-3">
                        <div class="flex items-center gap-2">
                          <span class="text-xs font-bold text-violet-700 bg-violet-50 px-2 py-0.5 rounded-full" style="font-family: 'Lexend', sans-serif;">{MSG_LABELS[msg.messageKey]}</span>
                          <span class="text-sm text-slate-700" style="font-family: 'Inter', sans-serif;">{msg.label}</span>
                        </div>
                      </td>
                      <td class="px-5 py-3"><span class="text-xs text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full" style="font-family: 'Inter', sans-serif;">{msg.messageType}</span></td>
                      <td class="px-5 py-3 text-sm font-semibold text-emerald-600" style="font-family: 'Lexend', sans-serif;">{s.sent}</td>
                      <td class="px-5 py-3 text-sm font-semibold text-red-500" style="font-family: 'Lexend', sans-serif;">{s.failed}</td>
                      <td class="px-5 py-3 text-sm text-slate-400" style="font-family: 'Lexend', sans-serif;">{s.skipped}</td>
                      <td class="px-5 py-3 text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">{s.lastSent ? relativeTime(s.lastSent) : '—'}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>
        <section>
          <h2 class="text-base font-semibold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">Recent Activity</h2>
          {recentLogs.length === 0 ? (
            <div class="bg-white rounded-2xl border border-slate-200 px-6 py-12 text-center">
              <p class="text-sm text-slate-400" style="font-family: 'Inter', sans-serif;">No messages sent yet. R1 fires automatically 2 hours after each appointment.</p>
            </div>
          ) : (
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-slate-100 bg-slate-50">
                    {['Customer', 'Message', 'Channel', 'Status', 'Time'].map(h => (
                      <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {recentLogs.map((log) => (
                    <tr class="hover:bg-slate-50 transition">
                      <td class="px-5 py-3">
                        <p class="font-medium text-slate-900 truncate max-w-[160px]" style="font-family: 'Inter', sans-serif;">{log.recipientName}</p>
                        <p class="text-xs text-slate-400 truncate max-w-[160px]">{log.recipientEmail}</p>
                      </td>
                      <td class="px-5 py-3">
                        <span class="text-xs font-bold text-violet-700 bg-violet-50 px-2 py-0.5 rounded-full" style="font-family: 'Lexend', sans-serif;">{MSG_LABELS[log.messageKey] ?? log.messageKey}</span>
                      </td>
                      <td class="px-5 py-3">
                        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${log.channel === 'email' ? 'bg-blue-50 text-blue-600' : 'bg-violet-50 text-violet-600'}`} style="font-family: 'Inter', sans-serif;">{log.channel}</span>
                      </td>
                      <td class="px-5 py-3">
                        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${log.status === 'sent' ? 'bg-emerald-50 text-emerald-600' : log.status === 'failed' ? 'bg-red-50 text-red-600' : 'bg-slate-100 text-slate-500'}`} style="font-family: 'Inter', sans-serif;">{log.status}</span>
                        {log.errorMessage && log.status !== 'sent' && (
                          <p class="text-xs text-slate-400 mt-0.5 max-w-[180px] truncate" title={log.errorMessage}>{log.errorMessage}</p>
                        )}
                      </td>
                      <td class="px-5 py-3 text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">{relativeTime(log._creationTime)}</td>
                    </tr>
                  ))}
