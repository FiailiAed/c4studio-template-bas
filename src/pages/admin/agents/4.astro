                <div class="step-ind-4 shrink-0 w-10 h-10 rounded-full border-2 border-slate-200 text-slate-400 bg-white flex items-center justify-center text-xs font-bold z-10" data-key={msg.messageKey} style="font-family: 'Lexend', sans-serif;">
                  {testMsgLabels[msg.messageKey] ?? msg.messageKey.toUpperCase()}
                </div>
                <div class="flex-1 pb-6 min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-0.5">
                    <p class="text-sm font-semibold text-slate-900" style="font-family: 'Inter', sans-serif;">{msg.label}</p>
                    <span class="result-badge-4 hidden text-xs font-medium px-2 py-0.5 rounded-full border" data-key={msg.messageKey}></span>
                  </div>
