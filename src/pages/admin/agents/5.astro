---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';
import { getAgent } from '@lib/agents';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

// Auto-initialize default messages on first visit
const existingMessages = await client.query(api.nurturing.listMessages, {});
if (existingMessages.length === 0) {
  await client.mutation(api.nurturing.initializeDefaults, {});
}

let successMessage: string | null = Astro.url.searchParams.get('success')
  ? 'Message updated successfully.'
  : null;
let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action') as string;

  try {
    if (action === 'update-message') {
      const messageKey = (data.get('messageKey') as string).trim();
      const channel = data.get('channel') as 'email' | 'sms' | 'both';
      if (!['email', 'sms', 'both'].includes(channel)) throw new Error('Invalid channel.');
      await client.mutation(api.nurturing.upsertMessage, {
        messageKey,
        enabled: data.get('enabled') === 'on',
        channel,
        smsBody: (data.get('smsBody') as string).trim(),
        emailSubject: (data.get('emailSubject') as string).trim(),
        emailBody: (data.get('emailBody') as string).trim(),
      });
      return Astro.redirect('/admin/agents/5?tab=messages&success=1');
    }
  } catch (e) {
    errorMessage = e instanceof Error ? e.message : 'Action failed.';
  }
}

const activeTab = Astro.url.searchParams.get('tab') ?? 'messages';

const [messages, stats, recentLogs, settings] = await Promise.all([
  client.query(api.nurturing.listMessages, {}),
  client.query(api.nurturing.getStats, {}),
  client.query(api.nurturing.listLogs, { limit: 100 }),
  client.query(api.settings.get, {}),
]);

const agent = getAgent(5)!;
const agentData = {
  longPrompt: agent.long.prompt,
  shortPrompt: agent.short.prompt,
  longVars: agent.long.variables,
  shortVars: agent.short.variables,
  longNote: agent.long.note ?? null,
  shortNote: agent.short.note ?? null,
};

const MESSAGE_KEY_LABELS: Record<string, string> = {
  m1: 'M1', m2: 'M2', m3: 'M3',
  m4a: 'M4a', m4b: 'M4b', m4c: 'M4c', m5: 'M5',
};

const CONTACT_MSG_KEYS = ['m1', 'm2', 'm3'];
const [rawContacts5, rawBookings5, rawLinks5] = await Promise.all([
  client.query(api.contacts.list, {}),
  client.query(api.bookings.listAll, {}),
  client.query(api.bookingLinks.list, {}),
]);
const linkNameMap5: Record<string, string> = {};
rawLinks5.forEach((l: { _id: string; name: string }) => { linkNameMap5[l._id] = l.name; });
const testContacts = rawContacts5.slice(0, 50).map(c => ({
  id: c._id as string,
  name: c.name,
  email: c.email,
  subject: c.subject ?? '',
}));
const testBookings = rawBookings5.slice(0, 50).map((b: { _id: string; name: string; email: string; date: string; startTime: string; bookingLinkId: string }) => ({
  id: b._id as string,
  name: b.name,
  email: b.email,
  date: b.date,
  startTime: b.startTime,
  linkName: linkNameMap5[b.bookingLinkId] ?? 'your appointment',
}));
const testMessages = messages.slice().sort((a, b) => a.order - b.order).map(m => ({
  ...m,
  entityType: CONTACT_MSG_KEYS.includes(m.messageKey) ? 'contact' : 'booking',
}));
const testMsgLabels: Record<string, string> = { m1: 'M1', m2: 'M2', m3: 'M3', m4a: 'M4a', m4b: 'M4b', m4c: 'M4c', m5: 'M5' };
const testSettings = {
  appName: settings?.appName ?? '',
  primaryService: settings?.primaryService ?? '',
  defaultBookingLink: settings?.defaultBookingLink ?? '',
};

function relativeTime(ts: number) {
  const diff = Date.now() - ts;
  if (diff < 60_000) return 'just now';
  if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;
  if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`;
  return `${Math.floor(diff / 86_400_000)}d ago`;
}
---

<BaseLayout title="Lead Nurturing — Agents">
  <div class="min-h-screen bg-slate-50">

    <!-- Nav -->
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition shrink-0" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300 shrink-0">/</span>
        <a href="/admin/agents" class="text-sm text-slate-500 hover:text-slate-900 transition shrink-0" style="font-family: 'Inter', sans-serif;">Agents</a>
        <span class="text-slate-300 shrink-0">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Lead Nurturing</span>
      </div>
      <div class="flex items-center gap-4 shrink-0">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-10">

      <!-- Page header -->
      <div class="flex items-start gap-4 mb-6">
        <div class="shrink-0 w-12 h-12 rounded-2xl bg-white border-2 border-emerald-400 flex items-center justify-center">
          <span class="text-lg font-bold text-slate-700" style="font-family: 'Lexend', sans-serif;">5</span>
        </div>
        <div>
          <div class="flex items-center gap-3 mb-1">
            <h1 class="text-2xl font-bold tracking-tight text-slate-900" style="font-family: 'Lexend', sans-serif;">Lead Nurturing</h1>
            <span class="text-xs font-semibold text-slate-500 bg-slate-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">Day 5</span>
            <span class="text-xs font-semibold text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">Active</span>
          </div>
          <p class="text-sm text-slate-500" style="font-family: 'Inter', sans-serif;">{agent.description}</p>
        </div>
      </div>

      {successMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-700" style="font-family: 'Inter', sans-serif;">{successMessage}</div>
      )}
      {errorMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700" style="font-family: 'Inter', sans-serif;">{errorMessage}</div>
      )}

      <!-- Tabs -->
      <div class="flex items-center gap-1 mb-8 bg-slate-100 rounded-xl p-1 w-fit">
        {(['messages', 'history', 'test', 'settings'] as const).map((tab) => (
          <button
            data-tab={tab}
            class={`tab-btn text-sm font-medium px-4 py-2 rounded-lg transition capitalize ${activeTab === tab ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'}`}
            style="font-family: 'Inter', sans-serif;"
          >
            {tab === 'settings' ? 'Prompt' : tab.charAt(0).toUpperCase() + tab.slice(1)}
          </button>
        ))}
      </div>

      <!-- ── Tab: Messages ──────────────────────────────────────── -->
      <div id="tab-messages" class={`tab-panel ${activeTab !== 'messages' ? 'hidden' : ''}`}>

        <!-- Stats strip -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
          {(['email','sms'] as const).map((ch) => {
            const chLogs = recentLogs.filter(l => l.channel === ch);
            const sent = chLogs.filter(l => l.status === 'sent').length;
            const total = chLogs.length;
            return (
              <div class="bg-white rounded-2xl border border-slate-200 px-5 py-4">
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">{ch === 'email' ? 'Email' : 'SMS'} sent</p>
                <p class="text-2xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{sent}</p>
                <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">of {total} attempts</p>
              </div>
            );
          })}
          <div class="bg-white rounded-2xl border border-slate-200 px-5 py-4">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">Sequences triggered</p>
            <p class="text-2xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{recentLogs.filter(l => l.messageKey === 'm1').length}</p>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">via contact form</p>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 px-5 py-4">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">Messages active</p>
            <p class="text-2xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{messages.filter(m => m.enabled).length}<span class="text-sm text-slate-400 font-normal"> / {messages.length}</span></p>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">&nbsp;</p>
          </div>
        </div>

        <!-- Amber note: SMS status -->
        <div class="flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-2xl px-5 py-4 mb-6">
          <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
          </svg>
          <p class="text-sm text-amber-800" style="font-family: 'Inter', sans-serif;">
            <strong>SMS is not yet active.</strong> Set channel to <em>Email</em> for now. SMS will become available once the Twilio integration is configured. All messages currently default to email-only.
          </p>
        </div>

        <!-- Message list -->
        <div class="flex flex-col gap-3">
          {messages.sort((a, b) => a.order - b.order).map((msg) => {
            const msgStats = stats[msg.messageKey] ?? { sent: 0, failed: 0, skipped: 0, lastSent: null };
            return (
              <details class="group bg-white rounded-2xl border border-slate-200 overflow-hidden">
                <summary class="flex items-center gap-4 px-6 py-4 cursor-pointer list-none hover:bg-slate-50 transition">
                  <!-- Key badge -->
                  <span class="shrink-0 w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-xs font-bold text-emerald-700" style="font-family: 'Lexend', sans-serif;">
                    {MESSAGE_KEY_LABELS[msg.messageKey]}
                  </span>

                  <!-- Info -->
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-slate-900" style="font-family: 'Inter', sans-serif;">{msg.label}</p>
                    <p class="text-xs text-slate-400 truncate" style="font-family: 'Inter', sans-serif;">{msg.triggerDescription}</p>
                  </div>

                  <!-- Stats -->
                  <div class="hidden sm:flex items-center gap-4 shrink-0">
                    <div class="text-right">
                      <p class="text-sm font-semibold text-slate-700" style="font-family: 'Lexend', sans-serif;">{msgStats.sent}</p>
                      <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">sent</p>
                    </div>
                    <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${msg.channel === 'email' ? 'bg-blue-50 text-blue-600 border border-blue-100' : msg.channel === 'sms' ? 'bg-violet-50 text-violet-600 border border-violet-100' : 'bg-emerald-50 text-emerald-600 border border-emerald-100'}`} style="font-family: 'Inter', sans-serif;">
                      {msg.channel}
                    </span>
                    <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${msg.enabled ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' : 'bg-slate-100 text-slate-400'}`} style="font-family: 'Inter', sans-serif;">
                      {msg.enabled ? 'on' : 'off'}
                    </span>
                  </div>

                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
                  </svg>
                </summary>

                <!-- Edit form -->
                <div class="border-t border-slate-100 px-6 py-6 bg-slate-50">
                  <form method="POST" class="flex flex-col gap-5">
                    <input type="hidden" name="action" value="update-message" />
                    <input type="hidden" name="messageKey" value={msg.messageKey} />

                    <!-- Enabled + Channel row -->
                    <div class="flex flex-wrap items-center gap-6">
                      <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="enabled" value="on" checked={msg.enabled} class="w-4 h-4 rounded" />
                        <span class="text-sm font-medium text-slate-700" style="font-family: 'Inter', sans-serif;">Enabled</span>
                      </label>
                      <div class="flex items-center gap-3">
                        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Channel</span>
                        {(['email', 'sms', 'both'] as const).map((ch) => (
                          <label class="flex items-center gap-1.5 cursor-pointer">
                            <input type="radio" name="channel" value={ch} checked={msg.channel === ch} class="w-4 h-4" />
                            <span class="text-sm text-slate-700 capitalize" style="font-family: 'Inter', sans-serif;">{ch}</span>
                          </label>
                        ))}
                      </div>
                    </div>

                    <!-- SMS Body -->
                    <div class="flex flex-col gap-1.5">
                      <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">
                        SMS Body <span class="normal-case font-normal text-slate-400">(≤160 chars with values substituted)</span>
                      </label>
                      <textarea name="smsBody" rows="2"
                        class="text-sm bg-white border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 resize-none font-mono"
                        style="font-family: 'ui-monospace', monospace;"
                      >{msg.smsBody}</textarea>
                    </div>

                    <!-- Email Subject -->
                    <div class="flex flex-col gap-1.5">
                      <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Email Subject</label>
                      <input type="text" name="emailSubject" value={msg.emailSubject}
                        class="text-sm bg-white border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900"
                        style="font-family: 'Inter', sans-serif;" />
                    </div>

                    <!-- Email Body -->
                    <div class="flex flex-col gap-1.5">
                      <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Email Body</label>
                      <textarea name="emailBody" rows="4"
                        class="text-sm bg-white border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 resize-y"
                        style="font-family: 'Inter', sans-serif;"
                      >{msg.emailBody}</textarea>
                      <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">
                        Variables: <code class="bg-slate-200 px-1 rounded">{'{{FIRST_NAME}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{SERVICE}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{BUSINESS_NAME}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{BOOKING_LINK}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{APPOINTMENT_DATE}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{APPOINTMENT_TIME}}'}</code> <code class="bg-slate-200 px-1 rounded">{'{{REBOOKING_LINK}}'}</code>
                      </p>
                    </div>

                    <div class="flex justify-end">
                      <button type="submit"
                        class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition"
                        style="font-family: 'Inter', sans-serif;">
                        Save message
                      </button>
                    </div>
                  </form>
                </div>
              </details>
            );
          })}
        </div>
      </div>

      <!-- ── Tab: History ───────────────────────────────────────── -->
      <div id="tab-history" class={`tab-panel ${activeTab !== 'history' ? 'hidden' : ''}`}>

        <!-- Per-message aggregate -->
        <section class="mb-8">
          <h2 class="text-base font-semibold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">Per-Message Stats</h2>
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-slate-100 bg-slate-50">
                  {['Message', 'Trigger', 'Sent', 'Failed', 'Skipped', 'Last Sent'].map((h) => (
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {messages.sort((a, b) => a.order - b.order).map((msg) => {
                  const s = stats[msg.messageKey] ?? { sent: 0, failed: 0, skipped: 0, lastSent: null };
                  return (
                    <tr class="hover:bg-slate-50 transition">
                      <td class="px-5 py-3">
                        <div class="flex items-center gap-2">
                          <span class="text-xs font-bold text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full" style="font-family: 'Lexend', sans-serif;">{MESSAGE_KEY_LABELS[msg.messageKey]}</span>
                          <span class="text-sm text-slate-700" style="font-family: 'Inter', sans-serif;">{msg.label}</span>
                        </div>
                      </td>
                      <td class="px-5 py-3 text-xs text-slate-400 max-w-xs truncate" style="font-family: 'Inter', sans-serif;">{msg.triggerDescription}</td>
                      <td class="px-5 py-3 text-sm font-semibold text-emerald-600" style="font-family: 'Lexend', sans-serif;">{s.sent}</td>
                      <td class="px-5 py-3 text-sm font-semibold text-red-500" style="font-family: 'Lexend', sans-serif;">{s.failed}</td>
                      <td class="px-5 py-3 text-sm text-slate-400" style="font-family: 'Lexend', sans-serif;">{s.skipped}</td>
                      <td class="px-5 py-3 text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">{s.lastSent ? relativeTime(s.lastSent) : '—'}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>

        <!-- Recent activity timeline -->
        <section>
          <h2 class="text-base font-semibold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">Recent Activity</h2>
          {recentLogs.length === 0 ? (
            <div class="bg-white rounded-2xl border border-slate-200 px-6 py-12 text-center">
              <p class="text-sm text-slate-400" style="font-family: 'Inter', sans-serif;">No messages sent yet. Sequences trigger automatically on contact form submission and booking creation.</p>
            </div>
          ) : (
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-slate-100 bg-slate-50">
                    {['Contact', 'Message', 'Channel', 'Status', 'Time'].map((h) => (
                      <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {recentLogs.map((log) => (
                    <tr class="hover:bg-slate-50 transition">
                      <td class="px-5 py-3">
                        <p class="font-medium text-slate-900 truncate max-w-[160px]" style="font-family: 'Inter', sans-serif;">{log.recipientName}</p>
                        <p class="text-xs text-slate-400 truncate max-w-[160px]">{log.recipientEmail}</p>
                      </td>
                      <td class="px-5 py-3">
                        <span class="text-xs font-bold text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full" style="font-family: 'Lexend', sans-serif;">{MESSAGE_KEY_LABELS[log.messageKey] ?? log.messageKey}</span>
                      </td>
                      <td class="px-5 py-3">
                        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${log.channel === 'email' ? 'bg-blue-50 text-blue-600' : 'bg-violet-50 text-violet-600'}`} style="font-family: 'Inter', sans-serif;">{log.channel}</span>
                      </td>
                      <td class="px-5 py-3">
                        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${log.status === 'sent' ? 'bg-emerald-50 text-emerald-600' : log.status === 'failed' ? 'bg-red-50 text-red-600' : 'bg-slate-100 text-slate-500'}`} style="font-family: 'Inter', sans-serif;">{log.status}</span>
                        {log.errorMessage && log.status !== 'sent' && (
                          <p class="text-xs text-slate-400 mt-0.5 max-w-[200px] truncate" title={log.errorMessage}>{log.errorMessage}</p>
                        )}
                      </td>
                      <td class="px-5 py-3 text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">{relativeTime(log._creationTime)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>
      </div>

      <!-- ── Tab: Test ────────────────────────────────────────── -->
      <div id="tab-test" class={`tab-panel ${activeTab !== 'test' ? 'hidden' : ''}`}>

        <!-- Setup card -->
        <div id="test-setup-5" class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-6">
          <div class="px-6 py-4 border-b border-slate-100">
            <h2 class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Test Setup</h2>
            <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">Real emails will be sent via Resend and logged with <code class="bg-slate-100 px-1 rounded">isTest: true</code> in History. M1–M3 use the contact; M4a–M5 use the booking.</p>
          </div>
          <div class="px-6 py-6 flex flex-col gap-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Contact <span class="normal-case font-normal text-slate-400">(M1–M3)</span></label>
                <select id="test-contact-5" class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900" style="font-family: 'Inter', sans-serif;">
                  <option value="">— Select a contact —</option>
                  {testContacts.map(c => (
                    <option value={c.id}>{c.name} ({c.email})</option>
                  ))}
                </select>
                {testContacts.length === 0 && <p class="text-xs text-amber-600" style="font-family: 'Inter', sans-serif;">No contacts yet.</p>}
              </div>
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Booking <span class="normal-case font-normal text-slate-400">(M4a–M5)</span></label>
                <select id="test-booking-5" class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900" style="font-family: 'Inter', sans-serif;">
                  <option value="">— Select a booking —</option>
                  {testBookings.map(b => (
                    <option value={b.id}>{b.name} · {b.linkName} · {b.date}</option>
                  ))}
                </select>
                {testBookings.length === 0 && <p class="text-xs text-amber-600" style="font-family: 'Inter', sans-serif;">No bookings yet.</p>}
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Test Email <span class="normal-case font-normal text-slate-400">(all steps delivered here)</span></label>
              <input id="test-email-5" type="email" placeholder="you@example.com"
                class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900"
                style="font-family: 'Inter', sans-serif;" />
            </div>
            <div class="flex justify-end">
              <button id="test-start-5" class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition" style="font-family: 'Inter', sans-serif;">
