            </div>
            <button id="test-reset-5" class="text-xs font-medium text-slate-500 hover:text-slate-900 transition shrink-0" style="font-family: 'Inter', sans-serif;">← Change setup</button>
          </div>

          <div class="flex flex-col">
            {testMessages.map((msg, i) => (
              <div class="relative flex gap-4" data-step={msg.messageKey}>
                {i < testMessages.length - 1 && (
                  <div class="absolute left-[19px] top-10 bottom-0 w-0.5 bg-slate-200 z-0" />
