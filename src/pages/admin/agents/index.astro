---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';
import { AGENTS } from '@lib/agents';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

// Load live stats for the three wired agents in parallel
const [
  nurturingMessages, nurturingStats,
  reactivationMessages, reactivationStats,
  reviewsMessages, reviewsStats,
] = await Promise.all([
  client.query(api.nurturing.listMessages, {}),
  client.query(api.nurturing.getStats, {}),
  client.query(api.reactivation.listMessages, {}),
  client.query(api.reactivation.getStats, {}),
  client.query(api.reviews.listMessages, {}),
  client.query(api.reviews.getStats, {}),
]);

// Aggregate total sent per wired agent
function totalSent(stats: Record<string, { sent: number }>) {
  return Object.values(stats).reduce((sum, s) => sum + s.sent, 0);
}

function activeCount(messages: { enabled: boolean }[]) {
  return messages.filter(m => m.enabled).length;
}

const liveStats = {
  3: { sent: totalSent(reactivationStats), active: activeCount(reactivationMessages), total: reactivationMessages.length },
  4: { sent: totalSent(reviewsStats),      active: activeCount(reviewsMessages.filter(m => m.messageType === 'automated')), total: reviewsMessages.filter(m => m.messageType === 'automated').length },
  5: { sent: totalSent(nurturingStats),    active: activeCount(nurturingMessages), total: nurturingMessages.length },
} as const;

// Split agents: live (wired to send pipeline) vs prompt-only
const liveAgents  = AGENTS.filter(a => [3, 4, 5].includes(a.id));
const promptAgents = AGENTS.filter(a => ![3, 4, 5].includes(a.id));

const ACCENT_BG: Record<number, string> = {
  1: 'bg-sky-50 border-sky-200',
  2: 'bg-rose-50 border-rose-200',
  3: 'bg-amber-50 border-amber-200',
  4: 'bg-violet-50 border-violet-200',
  5: 'bg-emerald-50 border-emerald-200',
  6: 'bg-orange-50 border-orange-200',
  7: 'bg-teal-50 border-teal-200',
};

const ACCENT_TEXT: Record<number, string> = {
  1: 'text-sky-700',
  2: 'text-rose-700',
  3: 'text-amber-700',
  4: 'text-violet-700',
  5: 'text-emerald-700',
  6: 'text-orange-700',
  7: 'text-teal-700',
};

const ACCENT_BADGE: Record<number, string> = {
  1: 'border-sky-400',
  2: 'border-rose-400',
  3: 'border-amber-400',
  4: 'border-violet-400',
  5: 'border-emerald-400',
  6: 'border-orange-400',
  7: 'border-teal-400',
};
---

<BaseLayout title="Agents Hub — Admin Portal">
  <div class="min-h-screen bg-slate-50">

    <!-- Nav -->
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Agents</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">

      <!-- Page header -->
      <div class="mb-10">
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-2" style="font-family: 'Lexend', sans-serif;">
          Agents
        </h1>
        <p class="text-slate-500" style="font-family: 'Inter', sans-serif;">
          7-day AI agency playbook. Live sequences fire automatically and log every send attempt. Prompt tools assemble copy for use in Claude.
        </p>
      </div>

      <!-- ── Live Sequences ──────────────────────────────────────── -->
      <section class="mb-12">
        <div class="flex items-center gap-3 mb-5">
          <h2 class="text-base font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Live Sequences</h2>
          <span class="text-xs font-medium text-emerald-600 bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">
            Email wired · SMS pending Twilio
          </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {liveAgents.map((agent) => {
            const stats = liveStats[agent.id as 3 | 4 | 5];
            return (
              <a
                href={`/admin/agents/${agent.id}`}
                class="group bg-white rounded-2xl border border-slate-200 hover:border-slate-300 hover:shadow-lg transition-all duration-200 overflow-hidden flex flex-col"
              >
                <!-- Card header -->
                <div class={`flex items-center gap-3 px-5 py-4 border-b border-slate-100 ${ACCENT_BG[agent.id]}`}>
                  <div class={`w-10 h-10 rounded-xl bg-white border-2 ${ACCENT_BADGE[agent.id]} flex items-center justify-center shrink-0`}>
                    <span class={`text-sm font-bold ${ACCENT_TEXT[agent.id]}`} style="font-family: 'Lexend', sans-serif;">{agent.id}</span>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-slate-900 truncate" style="font-family: 'Lexend', sans-serif;">{agent.name}</p>
                    <p class={`text-xs font-medium ${ACCENT_TEXT[agent.id]}`} style="font-family: 'Inter', sans-serif;">{agent.day}</p>
                  </div>
                </div>

                <!-- Stats row -->
                <div class="grid grid-cols-3 divide-x divide-slate-100 border-b border-slate-100">
                  <div class="px-4 py-3 text-center">
                    <p class="text-lg font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{stats.sent}</p>
                    <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">sent</p>
                  </div>
                  <div class="px-4 py-3 text-center">
                    <p class="text-lg font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{stats.active}</p>
                    <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">active</p>
                  </div>
                  <div class="px-4 py-3 text-center">
                    <p class="text-lg font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{stats.total}</p>
                    <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">messages</p>
                  </div>
                </div>

                <!-- Description + link -->
                <div class="px-5 py-4 flex-1 flex flex-col justify-between gap-3">
                  <p class="text-xs text-slate-500 leading-relaxed" style="font-family: 'Inter', sans-serif;">{agent.description}</p>
                  <span class={`inline-flex items-center gap-1 text-xs font-semibold ${ACCENT_TEXT[agent.id]} group-hover:underline`} style="font-family: 'Inter', sans-serif;">
                    Manage sequence
                    <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- ── Prompt Tools ────────────────────────────────────────── -->
      <section>
        <div class="flex items-center gap-3 mb-5">
          <h2 class="text-base font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Prompt Tools</h2>
          <span class="text-xs font-medium text-slate-500 bg-slate-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">
            Fill variables · copy to Claude
          </span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {promptAgents.map((agent) => (
            <a
              href={`/admin/agents/${agent.id}`}
              class="group bg-white rounded-2xl border border-slate-200 hover:border-slate-300 hover:shadow-md transition-all duration-200 p-5 flex flex-col gap-3"
            >
              <div class="flex items-center gap-3">
                <div class={`w-9 h-9 rounded-xl bg-white border-2 ${ACCENT_BADGE[agent.id]} flex items-center justify-center shrink-0`}>
                  <span class={`text-sm font-bold ${ACCENT_TEXT[agent.id]}`} style="font-family: 'Lexend', sans-serif;">{agent.id}</span>
                </div>
                <div>
                  <p class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">{agent.name}</p>
                  <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">{agent.day}</p>
                </div>
              </div>
              <p class="text-xs text-slate-500 leading-relaxed flex-1" style="font-family: 'Inter', sans-serif;">{agent.description}</p>
              <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500 group-hover:text-slate-900 transition-colors" style="font-family: 'Inter', sans-serif;">
                Open prompt
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>

      <!-- ── Roadmap note ────────────────────────────────────────── -->
      <div class="mt-12 flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-2xl px-5 py-4">
        <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/>
        </svg>
        <p class="text-sm text-amber-800" style="font-family: 'Inter', sans-serif;">
          <strong>v2 roadmap:</strong> Each agent will become a live chat interface connected to Claude. SMS delivery requires the Twilio integration. Prompt tools (Agents 1, 2, 6, 7) will be wired to live send pipelines as those sequences are built out.
        </p>
      </div>

    </main>
  </div>
</BaseLayout>
