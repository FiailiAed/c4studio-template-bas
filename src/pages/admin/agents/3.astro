                    <p class="text-sm font-semibold text-slate-900" style="font-family: 'Inter', sans-serif;">{msg.label}</p>
                    <span class="result-badge-3 hidden text-xs font-medium px-2 py-0.5 rounded-full border" data-key={msg.messageKey}></span>
                  </div>
                  <p class="text-xs text-slate-400 mb-3" style="font-family: 'Inter', sans-serif;">{msg.triggerDescription}</p>
                  <div class="step-panel-3 hidden bg-slate-50 rounded-2xl border border-slate-200 overflow-hidden" data-key={msg.messageKey}>
