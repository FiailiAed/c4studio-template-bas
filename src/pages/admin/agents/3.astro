            </div>
            <button id="test-reset-3" class="text-xs font-medium text-slate-500 hover:text-slate-900 transition shrink-0" style="font-family: 'Inter', sans-serif;">← Change setup</button>
          </div>

          <div class="flex flex-col">
            {testMessages.map((msg, i) => (
