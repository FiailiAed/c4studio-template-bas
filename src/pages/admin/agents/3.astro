                      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">Email Body</p>
                      <pre class="step-body-3 text-sm text-slate-700 whitespace-pre-wrap leading-relaxed" data-key={msg.messageKey} style="font-family: 'Inter', sans-serif;"></pre>
                    </div>
                    <div class="px-5 py-3 flex items-center justify-between gap-3 flex-wrap">
                      <span class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">
                        Channel: <strong class="text-slate-600">{msg.channel}</strong>
                        {!msg.enabled && <span class="ml-2 text-amber-600 font-semibold"> · disabled in config</span>}
                      </span>
                      <button class="send-btn-3 text-sm font-semibold bg-slate-900 text-white px-4 py-2 rounded-xl hover:bg-slate-700 transition disabled:opacity-50 disabled:cursor-not-allowed" data-key={msg.messageKey} style="font-family: 'Inter', sans-serif;">
                        Send {testMsgLabels[msg.messageKey] ?? msg.messageKey} →
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- ── Settings (Prompt) tab ──────────────────────────────── -->
      <div id="tab-settings" class={`tab-panel ${activeTab !== 'settings' ? 'hidden' : ''}`}>
        <div class="flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-2xl px-5 py-4 mb-6">
          <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/>
          </svg>
          <p class="text-sm text-amber-800" style="font-family: 'Inter', sans-serif;">
            <strong>Coming soon:</strong> This will become a live chat interface with the agent. For now, fill in the variables and paste the assembled prompt into Claude to generate customised reactivation copy for your market.
          </p>
        </div>
        <div class="flex items-center gap-1 mb-6 bg-slate-100 rounded-xl p-1 w-fit">
          <button id="btn-long" class="text-sm font-medium px-4 py-2 rounded-lg transition prompt-mode-btn active-mode" data-mode="long" style="font-family: 'Inter', sans-serif;">Long prompt</button>
          <button id="btn-short" class="text-sm font-medium px-4 py-2 rounded-lg transition prompt-mode-btn" data-mode="short" style="font-family: 'Inter', sans-serif;">Short prompt</button>
        </div>
        <div class="grid grid-cols-1 xl:grid-cols-[380px_1fr] gap-6 items-start">
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100">
              <h2 class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Variables</h2>
            </div>
            <div id="variables-form" class="px-6 py-5 flex flex-col gap-5"></div>
            <div id="no-variables-note" class="hidden px-6 py-8 text-center">
              <p id="no-variables-text" class="text-sm text-slate-400" style="font-family: 'Inter', sans-serif;"></p>
            </div>
          </div>
          <div class="flex flex-col gap-4">
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
              <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
                <div>
                  <h2 class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Prompt template</h2>
                  <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;"><span class="inline-block w-2.5 h-2.5 rounded bg-yellow-200 mr-1 align-middle"></span>Yellow fields replaced by your inputs.</p>
                </div>
                <button id="toggle-template" class="text-xs font-medium text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Hide</button>
              </div>
              <div id="template-wrapper" class="px-6 py-4 overflow-auto max-h-72">
                <pre id="template-display" class="text-xs text-slate-600 whitespace-pre-wrap leading-relaxed font-mono"></pre>
              </div>
            </div>
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
              <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
                <div>
                  <h2 class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Assembled prompt</h2>
                  <p class="text-xs text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">Unfilled variables appear as <code class="bg-slate-100 px-1 rounded">[KEY]</code></p>
                </div>
                <button id="copy-btn" class="inline-flex items-center gap-2 text-sm font-semibold bg-slate-900 text-white px-4 py-2 rounded-xl hover:bg-slate-700 transition" style="font-family: 'Inter', sans-serif;">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184"/></svg>
                  Copy prompt
                </button>
              </div>
              <div class="px-6 py-4">
                <textarea id="assembled-output" readonly rows="18" class="w-full text-xs text-slate-700 leading-relaxed font-mono bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 resize-y focus:outline-none"></textarea>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .active-mode { background-color: white; color: #0f172a; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
  .prompt-mode-btn:not(.active-mode) { color: #64748b; }
  mark { background-color: #fef9c3; color: #713f12; border-radius: 2px; padding: 0 2px; }
</style>

<script>
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.add('hidden'));
      document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
      document.querySelectorAll('.tab-btn').forEach((b) => {
        const active = (b as HTMLElement).dataset.tab === tab;
        b.classList.toggle('bg-white', active);
        b.classList.toggle('text-slate-900', active);
        b.classList.toggle('shadow-sm', active);
        b.classList.toggle('text-slate-500', !active);
      });
    });
  });
</script>

<script define:vars={{ testMessages, testMsgLabels, testContacts, testSettings }} is:inline>
(function () {
  const setupDiv = document.getElementById('test-setup-3');
  const stepperDiv = document.getElementById('test-stepper-3');
  const startBtn = document.getElementById('test-start-3');
  const resetBtn = document.getElementById('test-reset-3');
  const emailInput = document.getElementById('test-email-3');
  const contactSel = document.getElementById('test-contact-3');
  if (!setupDiv || !stepperDiv || !startBtn || !emailInput || !contactSel) return;

  const STATES = {};
  testMessages.forEach(function(m) { STATES[m.messageKey] = 'pending'; });

  function sub(text, vars) {
    return Object.entries(vars).reduce(function(t, kv) { return t.split('{{' + kv[0] + '}}').join(kv[1]); }, text);
  }

  function getVars(contact) {
    var first = contact.name.split(' ')[0] || contact.name;
    return {
      FIRST_NAME: first,
      BUSINESS_NAME: testSettings.appName || 'your business',
      RAFFLE_PRIZE: testSettings.rafflePrize || '[RAFFLE_PRIZE]',
      RAFFLE_LINK: testSettings.raffleLink || '[RAFFLE_LINK]',
      BOOKING_LINK: testSettings.defaultBookingLink || '[BOOKING_LINK]',
      REBOOKING_LINK: testSettings.defaultBookingLink || '[REBOOKING_LINK]',
    };
  }

  function setInd(key, state) {
    var el = document.querySelector('.step-ind-3[data-key="' + key + '"]');
    if (!el) return;
    el.className = 'step-ind-3 shrink-0 w-10 h-10 rounded-full border-2 flex items-center justify-center text-xs font-bold z-10 ';
    if (state === 'pending') el.className += 'border-slate-200 text-slate-400 bg-white';
    else if (state === 'active') el.className += 'border-slate-900 bg-slate-900 text-white';
    else if (state === 'sent') el.className += 'border-emerald-400 bg-emerald-50 text-emerald-700';
    else if (state === 'failed') el.className += 'border-red-400 bg-red-50 text-red-600';
  }

  function setBadge(key, state, error) {
    var el = document.querySelector('.result-badge-3[data-key="' + key + '"]');
    if (!el) return;
    el.className = 'result-badge-3 text-xs font-medium px-2 py-0.5 rounded-full border';
    if (state === 'sent') { el.textContent = '✓ sent'; el.className += ' bg-emerald-50 text-emerald-600 border-emerald-200'; }
    else if (state === 'failed') { el.textContent = '✗ ' + (error || 'failed'); el.className += ' bg-red-50 text-red-600 border-red-200'; }
  }

  function activateStep(key) {
    document.querySelectorAll('.step-panel-3').forEach(function(p) { p.classList.add('hidden'); });
    var panel = document.querySelector('.step-panel-3[data-key="' + key + '"]');
    if (!panel) return;
    panel.classList.remove('hidden');
    var msg = testMessages.find(function(m) { return m.messageKey === key; });
    var contact = testContacts.find(function(c) { return c.id === contactSel.value; });
    if (!msg || !contact) return;
    var vars = getVars(contact);
    var subj = document.querySelector('.step-subj-3[data-key="' + key + '"]');
    var body = document.querySelector('.step-body-3[data-key="' + key + '"]');
    if (subj) subj.textContent = sub(msg.emailSubject, vars);
    if (body) body.textContent = sub(msg.emailBody, vars);
  }

  startBtn.addEventListener('click', function() {
    var email = emailInput.value.trim();
    var cid = contactSel.value;
    if (!email) { alert('Enter a test email address.'); return; }
    if (!cid) { alert('Select a contact.'); return; }
    var contact = testContacts.find(function(c) { return c.id === cid; });
    document.getElementById('test-email-display-3').textContent = email;
    document.getElementById('test-contact-display-3').textContent = contact ? contact.name : cid;
    setupDiv.classList.add('hidden');
    stepperDiv.classList.remove('hidden');
    var first = testMessages[0];
    if (first) { STATES[first.messageKey] = 'active'; setInd(first.messageKey, 'active'); activateStep(first.messageKey); }
  });

  resetBtn && resetBtn.addEventListener('click', function() {
    testMessages.forEach(function(m) { STATES[m.messageKey] = 'pending'; setInd(m.messageKey, 'pending'); });
    document.querySelectorAll('.step-panel-3').forEach(function(p) { p.classList.add('hidden'); });
    document.querySelectorAll('.result-badge-3').forEach(function(b) { b.className = 'result-badge-3 hidden'; b.textContent = ''; });
    setupDiv.classList.remove('hidden');
    stepperDiv.classList.add('hidden');
  });

  document.querySelectorAll('.send-btn-3').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var key = btn.dataset.key;
      var email = emailInput.value.trim();
      var cid = contactSel.value;
      if (!key || !email || !cid) return;
      btn.disabled = true;
      btn.textContent = 'Sending…';
      try {
        var res = await fetch('/api/agents/test-send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ agent: 3, messageKey: key, contactId: cid, testEmail: email }),
        });
        var result = await res.json();
        if (result.ok) {
          STATES[key] = 'sent'; setInd(key, 'sent'); setBadge(key, 'sent', null);
          document.querySelector('.step-panel-3[data-key="' + key + '"]').classList.add('hidden');
          var next = testMessages.find(function(m) { return STATES[m.messageKey] === 'pending'; });
          if (next) { STATES[next.messageKey] = 'active'; setInd(next.messageKey, 'active'); activateStep(next.messageKey); }
        } else {
          STATES[key] = 'failed'; setInd(key, 'failed'); setBadge(key, 'failed', result.error);
          btn.disabled = false; btn.textContent = 'Retry →';
        }
      } catch (e) {
        STATES[key] = 'failed'; setInd(key, 'failed'); setBadge(key, 'failed', 'Network error');
        btn.disabled = false; btn.textContent = 'Retry →';
      }
    });
  });
})();
</script>

<script define:vars={{ agentData }}>
  let currentMode = 'long';
  const variablesForm = document.getElementById('variables-form');
  const noVarsNote = document.getElementById('no-variables-note');
  const noVarsText = document.getElementById('no-variables-text');
  const templateDisplay = document.getElementById('template-display');
  const assembledOutput = document.getElementById('assembled-output');
  const copyBtn = document.getElementById('copy-btn');
  const toggleTemplateBtn = document.getElementById('toggle-template');
  const templateWrapper = document.getElementById('template-wrapper');

  if (variablesForm && assembledOutput) {
    function escapeHtml(t) { return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function highlightVars(t) { return escapeHtml(t).replace(/\{\{([^}]+)\}\}/g,'<mark>{{$1}}</mark>'); }
    function getValues() { const v={}; document.querySelectorAll('[data-var-key]').forEach(el=>{v[el.dataset.varKey]=el.value.trim();}); return v; }
    function assemble(prompt,vars,values) { return vars.reduce((t,v)=>t.split(`{{${v.key}}}`).join(values[v.key]||`[${v.key}]`),prompt); }
    function updateOutput() { const vars=currentMode==='long'?agentData.longVars:agentData.shortVars; const prompt=currentMode==='long'?agentData.longPrompt:agentData.shortPrompt; assembledOutput.value=assemble(prompt,vars,getValues()); }
    function renderVars() {
      const vars=currentMode==='long'?agentData.longVars:agentData.shortVars; const note=currentMode==='long'?agentData.longNote:agentData.shortNote;
      variablesForm.innerHTML='';
      if(vars.length===0){variablesForm.classList.add('hidden');noVarsNote.classList.remove('hidden');noVarsText.textContent=note||'No variables.';return;}
      variablesForm.classList.remove('hidden');noVarsNote.classList.add('hidden');
      vars.forEach(v=>{
        const wrap=document.createElement('div');wrap.className='flex flex-col gap-1.5';
        const label=document.createElement('label');label.className='text-xs font-semibold text-slate-600 uppercase tracking-wide';label.style.fontFamily="'Inter',sans-serif";label.textContent=v.label+(v.required?' *':'');wrap.appendChild(label);
        const base='text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 w-full';
        let input;
        if(v.type==='textarea'){input=document.createElement('textarea');input.rows=v.rows||3;input.className=base+' resize-none';}
        else if(v.type==='select'){input=document.createElement('select');input.className=base;(v.options||[]).forEach(opt=>{const o=document.createElement('option');o.value=opt.startsWith('(')?'':opt;o.textContent=opt;input.appendChild(o);});}
        else{input=document.createElement('input');input.type='text';input.className=base;}
        input.dataset.varKey=v.key;input.style.fontFamily="'Inter',sans-serif";
        if(v.placeholder&&v.type!=='select')input.placeholder=v.placeholder;
        input.addEventListener('input',updateOutput);wrap.appendChild(input);
        if(v.helpText){const h=document.createElement('p');h.className='text-xs text-slate-400';h.style.fontFamily="'Inter',sans-serif";h.textContent=v.helpText;wrap.appendChild(h);}
        variablesForm.appendChild(wrap);
      });
    }
    function renderTemplate(){templateDisplay.innerHTML=highlightVars(currentMode==='long'?agentData.longPrompt:agentData.shortPrompt);}
    document.querySelectorAll('.prompt-mode-btn').forEach(btn=>{
      btn.addEventListener('click',()=>{currentMode=btn.dataset.mode;document.querySelectorAll('.prompt-mode-btn').forEach(b=>b.classList.toggle('active-mode',b.dataset.mode===currentMode));renderTemplate();renderVars();updateOutput();});
    });
    let templateVisible=true;
    toggleTemplateBtn?.addEventListener('click',()=>{templateVisible=!templateVisible;templateWrapper?.classList.toggle('hidden',!templateVisible);if(toggleTemplateBtn)toggleTemplateBtn.textContent=templateVisible?'Hide':'Show';});
    copyBtn?.addEventListener('click',async()=>{await navigator.clipboard.writeText(assembledOutput.value);const orig=copyBtn.innerHTML;copyBtn.innerHTML=`<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg> Copied!`;setTimeout(()=>{copyBtn.innerHTML=orig;},2000);});
    renderTemplate();renderVars();updateOutput();
  }
</script>
