---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';
import type { Id } from '@convex/dataModel';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

let successMessage: string | null = null;
let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action') as string;
  try {
    if (action === 'cancel') {
      const bookingId = data.get('bookingId') as Id<'bookings'>;
      await client.mutation(api.bookings.cancel, { id: bookingId });
      successMessage = 'Booking cancelled.';
    } else if (action === 'delete') {
      const bookingId = data.get('bookingId') as Id<'bookings'>;
      await client.mutation(api.bookings.remove, { id: bookingId });
      successMessage = 'Booking deleted.';
    }
  } catch {
    errorMessage = 'Action failed. Please try again.';
  }
}

const [allBookings, allLinks] = await Promise.all([
  client.query(api.bookings.listAll, {}),
  client.query(api.bookingLinks.list, {}),
]);

const linkMap = new Map(allLinks.map(l => [l._id, l]));

const statusFilter = Astro.url.searchParams.get('status') ?? 'confirmed';
const filtered = statusFilter === 'all'
  ? allBookings
  : allBookings.filter(b => b.status === statusFilter);

const confirmedCount = allBookings.filter(b => b.status === 'confirmed').length;
const cancelledCount = allBookings.filter(b => b.status === 'cancelled').length;

function fmtDate(d: string) {
  const [y, m, day] = d.split('-').map(Number);
  return new Date(y, m - 1, day).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
function fmt12h(t: string) {
  const [h, m] = t.split(':').map(Number);
  return `${h % 12 || 12}:${String(m).padStart(2, '0')} ${h >= 12 ? 'PM' : 'AM'}`;
}
function relativeTime(ts: number) {
  const diff = Date.now() - ts;
  if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;
  if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`;
  return `${Math.floor(diff / 86_400_000)}d ago`;
}
---

<BaseLayout title="Bookings — Admin Portal">
  <div class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Bookings</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/admin/booking-links" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Booking Links →</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <div class="flex items-start justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-slate-900" style="font-family: 'Lexend', sans-serif;">Bookings</h1>
          <p class="text-slate-500 mt-1" style="font-family: 'Inter', sans-serif;">All bookings across every booking link.</p>
        </div>
        <div class="flex items-center gap-3">
          <div class="text-center px-4 py-2 bg-emerald-50 rounded-xl border border-emerald-100">
            <p class="text-xl font-bold text-emerald-700" style="font-family: 'Lexend', sans-serif;">{confirmedCount}</p>
            <p class="text-xs text-emerald-600" style="font-family: 'Inter', sans-serif;">confirmed</p>
          </div>
          <div class="text-center px-4 py-2 bg-slate-100 rounded-xl border border-slate-200">
            <p class="text-xl font-bold text-slate-500" style="font-family: 'Lexend', sans-serif;">{cancelledCount}</p>
            <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">cancelled</p>
          </div>
        </div>
      </div>

      {successMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-700" style="font-family: 'Inter', sans-serif;">{successMessage}</div>
      )}
      {errorMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700" style="font-family: 'Inter', sans-serif;">{errorMessage}</div>
      )}

      <!-- Status filter -->
      <div class="flex items-center gap-2 mb-6">
        {[['confirmed', 'Confirmed'], ['cancelled', 'Cancelled'], ['all', 'All']].map(([val, label]) => (
          <a href={`?status=${val}`}
            class={`text-sm font-medium px-4 py-2 rounded-xl transition ${statusFilter === val ? 'bg-slate-900 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:border-slate-300'}`}
            style="font-family: 'Inter', sans-serif;">{label}</a>
        ))}
      </div>

      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        {filtered.length === 0 ? (
          <div class="px-6 py-16 text-center">
            <p class="text-sm text-slate-400" style="font-family: 'Inter', sans-serif;">No bookings found.</p>
          </div>
        ) : (
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-100 bg-slate-50">
                {['Contact', 'Booking Link', 'Date & Time', 'Status', 'Booked', ''].map(h => (
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">{h}</th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {filtered.map((b) => {
                const link = linkMap.get(b.bookingLinkId);
                return (
                  <tr class="hover:bg-slate-50 transition">
                    <td class="px-5 py-4">
                      <p class="font-medium text-slate-900 truncate max-w-[160px]" style="font-family: 'Inter', sans-serif;">{b.name}</p>
                      <p class="text-xs text-slate-400 truncate max-w-[160px]">{b.email}</p>
                      {b.phone && <p class="text-xs text-slate-400">{b.phone}</p>}
                    </td>
                    <td class="px-5 py-4">
                      {link ? (
                        <a href={`/admin/booking-links/${link._id}`} class="text-sm text-slate-700 hover:text-slate-900 hover:underline" style="font-family: 'Inter', sans-serif;">{link.name}</a>
                      ) : (
                        <span class="text-xs text-slate-400 font-mono">{b.bookingLinkId}</span>
                      )}
                    </td>
                    <td class="px-5 py-4">
                      <p class="text-sm font-medium text-slate-900" style="font-family: 'Inter', sans-serif;">{fmtDate(b.date)}</p>
                      <p class="text-xs text-slate-400">{fmt12h(b.startTime)}</p>
                    </td>
                    <td class="px-5 py-4">
                      <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${b.status === 'confirmed' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' : 'bg-slate-100 text-slate-400'}`} style="font-family: 'Inter', sans-serif;">
                        {b.status}
                      </span>
                    </td>
                    <td class="px-5 py-4 text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">{relativeTime(b._creationTime)}</td>
                    <td class="px-5 py-4 text-right">
                      {b.status === 'confirmed' && (
                        <form method="POST" onsubmit={`return confirm('Cancel booking for ${b.name}?')`} class="inline">
                          <input type="hidden" name="action" value="cancel" />
                          <input type="hidden" name="bookingId" value={b._id} />
                          <button type="submit" class="text-xs font-medium text-slate-500 hover:text-slate-900 bg-slate-100 hover:bg-slate-200 px-3 py-1.5 rounded-lg transition" style="font-family: 'Inter', sans-serif;">Cancel</button>
                        </form>
                      )}
                      {b.status === 'cancelled' && (
                        <form method="POST" onsubmit={`return confirm('Permanently delete this booking?')`} class="inline">
                          <input type="hidden" name="action" value="delete" />
                          <input type="hidden" name="bookingId" value={b._id} />
                          <button type="submit" class="text-xs font-medium text-red-400 hover:text-red-600 px-3 py-1.5 rounded-lg transition" style="font-family: 'Inter', sans-serif;">Delete</button>
                        </form>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        )}
      </div>
    </main>
  </div>
</BaseLayout>
