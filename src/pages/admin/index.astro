---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);
const user = await client.query(api.users.getByClerkId, { clerkId: userId });

if (!user) return Astro.redirect('/onboarding');
if (user.role !== 'admin') return Astro.redirect('/dashboard');

const [funnels, shops, bookingLinks, emailTemplates, emailLogs, raffles] = await Promise.all([
  client.query(api.funnels.list, {}),
  client.query(api.shops.list, {}),
  client.query(api.bookingLinks.list, {}),
  client.query(api.emailTemplates.list, {}),
  client.query(api.emailLogs.list, {}),
  client.query(api.raffles.list, {}),
]);
---

<BaseLayout title="Admin Portal — c4studio BAS">
  <div class="min-h-screen bg-slate-50">
    <!-- Nav -->
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Admin Portal</span>
        <span class="text-xs font-medium bg-red-100 text-red-700 px-2 py-0.5 rounded-full" style="font-family: 'Inter', sans-serif;">admin</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <a href="/dashboard" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Dashboard</a>
        <UserButton />
        <SignOutButton>
          <button
            class="text-sm text-slate-500 hover:text-slate-900 transition"
            style="font-family: 'Inter', sans-serif;"
          >
            Sign out
          </button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-2" style="font-family: 'Lexend', sans-serif;">
        Admin Portal
      </h1>
      <p class="text-slate-500 mb-10" style="font-family: 'Inter', sans-serif;">
        Manage content, users, and site configuration.
      </p>

      {([
        {
          heading: 'Management',
          subheading: 'Core tools for running the application.',
          modules: [
            { label: 'Users',    href: '/admin/users',    desc: 'View and manage user accounts and roles',          color: 'border-violet-400', status: 'active' },
            { label: 'Pages',    href: '/admin/pages',    desc: 'Control public page visibility and status',        color: 'border-pink-400',    status: 'active' },
            { label: 'Bookings', href: '/admin/bookings', desc: 'All bookings across every booking link',           color: 'border-teal-400',   status: 'active' },
            { label: 'Billing',  href: '/admin/billing',  desc: 'Stripe payments, subscriptions, and invoices',     color: 'border-indigo-400', status: 'active' },
            { label: 'Settings', href: '/admin/settings', desc: 'Site configuration and preferences',               color: 'border-slate-400',  status: 'active' },
            { label: 'Raffles',  href: '/admin/raffles',  desc: `${raffles.length} raffle${raffles.length !== 1 ? 's' : ''} — entries, draw, and winner tracking`,  color: 'border-amber-400',  status: 'active' },
          ],
        },
        {
          heading: 'Content',
          subheading: 'Manage the content displayed on the public site.',
          modules: [
            { label: 'Blog Posts',   href: '/admin/posts',        desc: 'Create and publish blog content',      color: 'border-emerald-400', status: 'active'  },
            { label: 'Testimonials', href: '/admin/testimonials', desc: 'Approve and feature reviews',          color: 'border-amber-400',   status: 'active'  },
            { label: 'Contacts',     href: '/admin/contacts',     desc: 'View contact form submissions',        color: 'border-cyan-400',    status: 'active'  },
            { label: 'Gallery',      href: '/admin/gallery',      desc: 'Upload and manage media',              color: 'border-pink-400',    status: 'active'  },
            { label: 'Pricing',      href: '/admin/pricing',      desc: 'Manage pricing tiers',                 color: 'border-green-400',   status: 'active'  },
          ],
        },
      ] as const).map(({ heading, subheading, modules }) => (
        <section class="mb-10">
          <div class="mb-4">
            <h2 class="text-lg font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">{heading}</h2>
            <p class="text-sm text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">{subheading}</p>
          </div>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            {modules.map(({ label, href, desc, color, status }) => (
              <a
                href={href}
                class={`group bg-white rounded-2xl border-l-4 border border-slate-200 ${color} p-5 hover:shadow-md transition`}
              >
                <div class="flex items-center justify-between gap-2 mb-1">
                  <p class="text-sm font-semibold text-slate-900 group-hover:underline" style="font-family: 'Inter', sans-serif;">{label}</p>
                  <span class={`inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full shrink-0 ${status === 'active' ? 'text-emerald-600 bg-emerald-50' : 'text-slate-400 bg-slate-100'}`} style="font-family: 'Inter', sans-serif;">
                    {status === 'active' && (
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                      </svg>
                    )}
                    {status}
                  </span>
                </div>
                <p class="text-xs text-slate-500" style="font-family: 'Inter', sans-serif;">{desc}</p>
              </a>
            ))}
          </div>
        </section>
      ))}

      <!-- ── Communications ───────────────────────────────────────── -->
      <section class="mb-10">
        <div class="flex items-end justify-between mb-4">
          <div>
            <h2 class="text-lg font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Communications</h2>
            <p class="text-sm text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">Send emails, manage templates, and view history via Resend.</p>
          </div>
          <a href="/admin/communications" class="text-xs font-semibold text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">
            Open hub →
          </a>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {([
            { label: 'Compose',    href: '/admin/communications/compose',   desc: 'Send a one-off email to any address or user',         color: 'border-sky-400',     status: 'active' },
            { label: 'Broadcast',  href: '/admin/communications/broadcast', desc: 'Email all registered users at once',                  color: 'border-rose-400',    status: 'active' },
            { label: 'Templates',  href: '/admin/communications/templates', desc: `${emailTemplates.length} saved template${emailTemplates.length !== 1 ? 's' : ''}`, color: 'border-violet-400', status: 'active' },
            { label: 'History',    href: '/admin/communications/history',   desc: `${emailLogs.length} email${emailLogs.length !== 1 ? 's' : ''} sent`, color: 'border-emerald-400', status: 'active' },
          ] as const).map(({ label, href, desc, color }) => (
            <a
              href={href}
              class={`group bg-white rounded-2xl border-l-4 border border-slate-200 ${color} p-5 hover:shadow-md transition`}
            >
              <div class="flex items-center justify-between gap-2 mb-1">
                <p class="text-sm font-semibold text-slate-900 group-hover:underline" style="font-family: 'Inter', sans-serif;">{label}</p>
                <span class="inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full shrink-0 text-emerald-600 bg-emerald-50" style="font-family: 'Inter', sans-serif;">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                  </svg>
                  active
                </span>
              </div>
              <p class="text-xs text-slate-500" style="font-family: 'Inter', sans-serif;">{desc}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- ── Agents ───────────────────────────────────────── -->
      <section class="mb-10">
        <div class="flex items-end justify-between mb-4">
          <div>
            <h2 class="text-lg font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Agents</h2>
            <p class="text-sm text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">7-day AI agency playbook — live sequences + prompt assembly tools.</p>
          </div>
          <a href="/admin/agents" class="text-xs font-semibold text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">
            View hub →
          </a>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {([
            { id: 1, label: 'Market Selection',    href: '/admin/agents/1', desc: 'Ranked top-3 market recommendation based on your background and budget',               color: 'border-sky-400',     day: 'Day 1' },
            { id: 2, label: 'Franchise Research',  href: '/admin/agents/2', desc: 'Top 10 franchise brands ranked by community size and growth signal',                   color: 'border-rose-400',    day: 'Day 2' },
            { id: 3, label: 'Reactivation Copy',   href: '/admin/agents/3', desc: '3-day SMS + email campaign to re-engage dormant leads with zero ad spend',             color: 'border-amber-400',   day: 'Day 3' },
            { id: 4, label: 'Reviews & Referrals', href: '/admin/agents/4', desc: 'All 5 messages for automated review collection and a referral raffle system',          color: 'border-violet-400',  day: 'Day 4' },
            { id: 5, label: 'Lead Nurturing',      href: '/admin/agents/5', desc: '5-message sequence from instant response through no-show win-back',                    color: 'border-emerald-400', day: 'Day 5' },
            { id: 6, label: 'Ads Strategist',      href: '/admin/agents/6', desc: 'Analyze competitor Facebook ads and generate 3 ad variations for your offer',          color: 'border-orange-400',  day: 'Day 6' },
            { id: 7, label: 'Sales Trainer',       href: '/admin/agents/7', desc: '7-step sales framework — drill mode roleplay or real call transcript review',          color: 'border-teal-400',    day: 'Day 7' },
          ] as const).map(({ label, href, desc, color, day }) => (
            <a
              href={href}
              class={`group bg-white rounded-2xl border-l-4 border border-slate-200 ${color} p-5 hover:shadow-md transition`}
            >
              <div class="flex items-center justify-between gap-2 mb-2">
                <p class="text-sm font-semibold text-slate-900 group-hover:underline" style="font-family: 'Inter', sans-serif;">{label}</p>
                <span class="inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full shrink-0 text-emerald-600 bg-emerald-50" style="font-family: 'Inter', sans-serif;">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                  </svg>
                  active
                </span>
              </div>
              <p class="text-xs text-slate-500 mb-1 line-clamp-2" style="font-family: 'Inter', sans-serif;">{desc}</p>
              <span class="text-xs font-medium text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full" style="font-family: 'Inter', sans-serif;">{day}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- ── Development ───────────────────────────────────────── -->
      <section class="mb-10">
        <div class="flex items-end justify-between mb-4">
          <div>
            <h2 class="text-lg font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Development</h2>
            <p class="text-sm text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">Project roadmap, release history, and developer task tracking.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {([
            { label: 'Task Board', href: '/admin/dev',  desc: 'All 80 tracked tasks — complete, planned, tabled, and overlooked gaps', color: 'border-amber-400' },
            { label: 'Roadmap',    href: '/roadmap',    desc: 'Upcoming versions and planned features', color: 'border-sky-400',   external: true },
            { label: 'Changelog',  href: '/changelog',  desc: 'Release history and shipped features',   color: 'border-rose-400',  external: true },
          ] as const).map(({ label, href, desc, color, external }) => (
            <a
              href={href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
              class={`group bg-white rounded-2xl border-l-4 border border-slate-200 ${color} p-5 hover:shadow-md transition`}
            >
              <div class="flex items-center justify-between gap-2 mb-2">
                <p class="text-sm font-semibold text-slate-900 group-hover:underline" style="font-family: 'Inter', sans-serif;">{label}</p>
                <span class="inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full shrink-0 text-emerald-600 bg-emerald-50" style="font-family: 'Inter', sans-serif;">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                  </svg>
                  active
                </span>
              </div>
              <p class="text-xs text-slate-500 mb-1 line-clamp-2" style="font-family: 'Inter', sans-serif;">{desc}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- ── Funnels (dynamic) ───────────────────────────────────── -->
      {([
        { heading: 'Funnels', subheading: 'Landing pages and marketing funnels.', items: funnels, base: '/admin/funnels', accentColor: 'border-emerald-400', createLabel: '+ New funnel' },
        { heading: 'Shops', subheading: 'Ecommerce shops and product listings.', items: shops, base: '/admin/shops', accentColor: 'border-orange-400', createLabel: '+ New shop' },
        { heading: 'Booking Links', subheading: 'Booking links for meetings and services.', items: bookingLinks, base: '/admin/booking-links', accentColor: 'border-teal-400', createLabel: '+ New link' },
      ]).map(({ heading, subheading, items, base, accentColor, createLabel }) => (
        <section class="mb-10">
          <div class="flex items-end justify-between mb-4">
            <div>
              <h2 class="text-lg font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">{heading}</h2>
              <p class="text-sm text-slate-400 mt-0.5" style="font-family: 'Inter', sans-serif;">{subheading}</p>
            </div>
            <a href={base} class="text-xs font-semibold text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">
              View all →
            </a>
          </div>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            {items.map((item) => (
              <a
                href={`${base}/${item._id}`}
                class={`group bg-white rounded-2xl border-l-4 border border-slate-200 ${accentColor} p-5 hover:shadow-md transition`}
              >
                <div class="flex items-center justify-between gap-2 mb-1">
                  <p class="text-sm font-semibold text-slate-900 group-hover:underline truncate" style="font-family: 'Inter', sans-serif;">{item.name}</p>
                  <span class={`inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full shrink-0 ${item.published ? 'text-emerald-600 bg-emerald-50' : 'text-slate-400 bg-slate-100'}`} style="font-family: 'Inter', sans-serif;">
                    {item.published && (
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                      </svg>
                    )}
                    {item.published ? 'published' : 'draft'}
                  </span>
                </div>
                <p class="text-xs font-mono text-slate-400">{item.slug}</p>
                {item.description && <p class="text-xs text-slate-500 mt-1.5 truncate" style="font-family: 'Inter', sans-serif;">{item.description}</p>}
              </a>
            ))}
            <!-- Create new card -->
            <a
              href={base}
              class="group flex flex-col items-center justify-center gap-2 bg-white rounded-2xl border-2 border-dashed border-slate-200 hover:border-slate-400 p-5 transition text-center"
            >
              <div class="w-8 h-8 rounded-full bg-slate-100 group-hover:bg-slate-200 flex items-center justify-center transition">
                <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                </svg>
              </div>
              <p class="text-xs font-semibold text-slate-500 group-hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">{createLabel}</p>
            </a>
          </div>
        </section>
      ))}
    </main>
  </div>
</BaseLayout>
