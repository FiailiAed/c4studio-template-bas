---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  try {
    const title = (data.get('title') as string).trim();
    const slug = (data.get('slug') as string).trim();
    if (!title || !slug) throw new Error('Title and slug are required.');
    const newPostId = await client.mutation(api.posts.create, {
      title,
      slug,
      body: '',
      excerpt: undefined,
      authorId: currentUser._id,
      published: false,
      tags: [],
    });
    return Astro.redirect(`/admin/posts/${newPostId}`);
  } catch (e) {
    errorMessage = e instanceof Error ? e.message : 'Failed to create post.';
  }
}

const posts = await client.query(api.posts.list, {});
const publishedCount = posts.filter(p => p.published).length;
---

<BaseLayout title="Posts — Admin Portal">
  <div class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Posts</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/blog" target="_blank" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">View /blog ↗</a>
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-slate-900" style="font-family: 'Lexend', sans-serif;">Posts</h1>
          <p class="text-slate-500 mt-1" style="font-family: 'Inter', sans-serif;">
            {posts.length} {posts.length === 1 ? 'post' : 'posts'}
            {publishedCount > 0 && (
              <span class="ml-2 inline-flex items-center text-xs font-semibold bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full">
                {publishedCount} published
              </span>
            )}
          </p>
        </div>
        <button
          onclick="document.getElementById('create-form').classList.toggle('hidden')"
          class="text-sm font-semibold bg-slate-900 text-white px-4 py-2.5 rounded-xl hover:bg-slate-700 transition"
          style="font-family: 'Inter', sans-serif;"
        >
          + New post
        </button>
      </div>

      {errorMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700" style="font-family: 'Inter', sans-serif;">{errorMessage}</div>
      )}

      <!-- Create form -->
      <div id="create-form" class="bg-white rounded-2xl border border-slate-200 p-6 mb-6 hidden">
        <h2 class="text-base font-semibold text-slate-900 mb-5" style="font-family: 'Lexend', sans-serif;">New post</h2>
        <form method="POST" class="flex flex-col gap-4">
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Title <span class="text-red-500">*</span></label>
              <input
                id="post-title"
                type="text"
                name="title"
                required
                placeholder="My first post"
                class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900"
                style="font-family: 'Inter', sans-serif;"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Slug <span class="text-red-500">*</span></label>
              <input
                id="post-slug"
                type="text"
                name="slug"
                required
                placeholder="my-first-post"
                class="text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 font-mono"
                style="font-family: 'Inter', sans-serif;"
              />
            </div>
          </div>
          <div class="flex justify-end">
            <button
              type="submit"
              class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition"
              style="font-family: 'Inter', sans-serif;"
            >
              Create &amp; edit
            </button>
          </div>
        </form>
      </div>

      <!-- Post list -->
      {posts.length === 0 ? (
        <div class="bg-white rounded-2xl border border-slate-200 p-16 text-center">
          <p class="text-slate-400 text-sm mb-4" style="font-family: 'Inter', sans-serif;">No posts yet.</p>
          <button
            onclick="document.getElementById('create-form').classList.remove('hidden'); document.getElementById('post-title').focus()"
            class="text-sm font-semibold text-slate-600 hover:text-slate-900 transition"
            style="font-family: 'Inter', sans-serif;"
          >
            Write your first post →
          </button>
        </div>
      ) : (
        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-100 bg-slate-50">
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Title</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Author</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Status</th>
                <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Date</th>
                <th class="px-5 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {posts.map((post) => {
                const date = post.publishedAt
                  ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
                  : new Date(post._creationTime).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                return (
                  <tr class="hover:bg-slate-50 transition">
                    <td class="px-5 py-4 max-w-xs">
                      <p class="font-medium text-slate-900 truncate" style="font-family: 'Inter', sans-serif;">{post.title}</p>
                      <p class="text-xs font-mono text-slate-400 mt-0.5">{post.slug}</p>
                    </td>
                    <td class="px-5 py-4 text-slate-500 text-xs" style="font-family: 'Inter', sans-serif;">{post.authorName}</td>
                    <td class="px-5 py-4">
                      {post.published ? (
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-emerald-600 bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">
                          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                          </svg>
                          published
                        </span>
                      ) : (
                        <span class="text-xs font-medium text-slate-400 bg-slate-100 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">draft</span>
                      )}
                    </td>
                    <td class="px-5 py-4 text-slate-500 text-xs" style="font-family: 'Inter', sans-serif;">{date}</td>
                    <td class="px-5 py-4 text-right">
                      <a
                        href={`/admin/posts/${post._id}`}
                        class="text-xs font-medium text-slate-600 hover:text-slate-900 bg-slate-100 hover:bg-slate-200 px-3 py-1.5 rounded-lg transition"
                        style="font-family: 'Inter', sans-serif;"
                      >
                        Edit
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </main>
  </div>
</BaseLayout>

<script>
  const titleInput = document.getElementById('post-title') as HTMLInputElement | null;
  const slugInput = document.getElementById('post-slug') as HTMLInputElement | null;
  titleInput?.addEventListener('input', () => {
    if (slugInput && !slugInput.dataset.edited) {
      slugInput.value = titleInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }
  });
  slugInput?.addEventListener('input', () => {
    if (slugInput.value) slugInput.dataset.edited = 'true';
    else delete slugInput.dataset.edited;
  });
</script>
