---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

const billingData = await client.query(api.users.adminGetBillingData, {}) ?? [];

// Aggregate stats
const totalCustomers  = billingData.filter(r => r.subscriptions.length > 0 || r.payments.length > 0).length;
const activeSubs      = billingData.flatMap(r => r.subscriptions).filter(s => s.status === 'active').length;
const totalPayments   = billingData.flatMap(r => r.payments).filter(p => p.status === 'succeeded').length;
const totalRevenue    = billingData.flatMap(r => r.payments)
  .filter(p => p.status === 'succeeded')
  .reduce((sum, p) => sum + p.amount, 0);

const allPayments = billingData
  .flatMap(r => r.payments.map(p => ({ ...p, user: r.user })))
  .sort((a, b) => b.created - a.created)
  .slice(0, 20);

const allSubscriptions = billingData
  .flatMap(r => r.subscriptions.map(s => ({ ...s, user: r.user })))
  .sort((a, b) => b.currentPeriodEnd - a.currentPeriodEnd);

function formatCurrency(amount: number, currency: string = 'usd') {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency }).format(amount / 100);
}

function formatDate(ts: number) {
  return new Date(ts * 1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const subStatusColor: Record<string, string> = {
  active:             'bg-emerald-100 text-emerald-700',
  trialing:           'bg-blue-100 text-blue-700',
  past_due:           'bg-amber-100 text-amber-700',
  canceled:           'bg-slate-100 text-slate-500',
  unpaid:             'bg-red-100 text-red-700',
  paused:             'bg-purple-100 text-purple-700',
  incomplete:         'bg-amber-100 text-amber-700',
  incomplete_expired: 'bg-red-100 text-red-700',
};

const paymentStatusColor: Record<string, string> = {
  succeeded:           'bg-emerald-100 text-emerald-700',
  processing:          'bg-blue-100 text-blue-700',
  requires_action:     'bg-amber-100 text-amber-700',
  requires_payment_method: 'bg-red-100 text-red-700',
  canceled:            'bg-slate-100 text-slate-500',
};

const convexSiteUrl = import.meta.env.CONVEX_SITE_URL ?? '';
---

<BaseLayout title="Billing — Admin Portal">
  <div class="min-h-screen bg-slate-50">
    <!-- Nav -->
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Billing</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <a href="/dashboard" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Dashboard</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-12">
      <div class="flex items-start justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-slate-900" style="font-family: 'Lexend', sans-serif;">Billing</h1>
          <p class="text-slate-500 mt-1" style="font-family: 'Inter', sans-serif;">Stripe payment and subscription data</p>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="https://dashboard.stripe.com/test/payments"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 hover:border-slate-400 px-3.5 py-2 rounded-xl transition"
            style="font-family: 'Inter', sans-serif;"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
            </svg>
            Stripe Dashboard
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
        {[
          { label: 'Stripe Customers',    value: totalCustomers,                color: 'border-violet-400' },
          { label: 'Active Subscriptions', value: activeSubs,                   color: 'border-emerald-400' },
          { label: 'Payments Collected',  value: totalPayments,                 color: 'border-blue-400' },
          { label: 'Total Revenue',       value: formatCurrency(totalRevenue),  color: 'border-indigo-400' },
        ].map(({ label, value, color }) => (
          <div class={`bg-white rounded-2xl border border-slate-200 border-l-4 ${color} p-5`}>
            <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1" style="font-family: 'Inter', sans-serif;">{label}</p>
            <p class="text-2xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">{value}</p>
          </div>
        ))}
      </div>

      <!-- Webhook endpoint callout -->
      <div class="bg-slate-900 text-slate-300 rounded-2xl px-5 py-4 mb-10 flex items-center justify-between gap-4 flex-wrap">
        <div>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-0.5" style="font-family: 'Inter', sans-serif;">Webhook Endpoint</p>
          <p class="text-sm font-mono text-slate-100">{convexSiteUrl}/stripe/webhook</p>
        </div>
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-400 bg-emerald-900/40 px-2.5 py-1 rounded-full" style="font-family: 'Inter', sans-serif;">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span>
          Listening
        </span>
      </div>

      <!-- Subscriptions table -->
      <section class="mb-10">
        <h2 class="text-lg font-semibold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">
          Subscriptions
          <span class="ml-2 text-sm font-normal text-slate-400">{allSubscriptions.length}</span>
        </h2>

        {allSubscriptions.length === 0 ? (
          <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center">
            <p class="text-sm text-slate-400" style="font-family: 'Inter', sans-serif;">No subscriptions yet.</p>
          </div>
        ) : (
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-slate-100 bg-slate-50">
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">User</th>
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Status</th>
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Price</th>
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Renews</th>
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Cancel at end</th>
                  <th class="px-5 py-3"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {allSubscriptions.map((sub) => (
                  <tr class="hover:bg-slate-50 transition">
                    <td class="px-5 py-4">
                      <p class="font-medium text-slate-900" style="font-family: 'Inter', sans-serif;">{sub.user.name ?? sub.user.email}</p>
                      <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">{sub.user.email}</p>
                    </td>
                    <td class="px-5 py-4">
                      <span class={`inline-flex text-xs font-medium px-2 py-0.5 rounded-full ${subStatusColor[sub.status] ?? 'bg-slate-100 text-slate-500'}`} style="font-family: 'Inter', sans-serif;">
                        {sub.status}
                      </span>
                    </td>
                    <td class="px-5 py-4 text-slate-600 font-mono text-xs">{sub.priceId}</td>
                    <td class="px-5 py-4 text-slate-600" style="font-family: 'Inter', sans-serif;">{formatDate(sub.currentPeriodEnd)}</td>
                    <td class="px-5 py-4">
                      {sub.cancelAtPeriodEnd
                        ? <span class="text-xs text-amber-600 font-medium" style="font-family: 'Inter', sans-serif;">Yes</span>
                        : <span class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">No</span>
                      }
                    </td>
                    <td class="px-5 py-4 text-right">
                      <a
                        href={`https://dashboard.stripe.com/test/subscriptions/${sub.stripeSubscriptionId}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs text-slate-500 hover:text-slate-900 underline underline-offset-2"
                        style="font-family: 'Inter', sans-serif;"
                      >
                        View →
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>

      <!-- Recent Payments table -->
      <section>
        <h2 class="text-lg font-semibold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">
          Recent Payments
          <span class="ml-2 text-sm font-normal text-slate-400">{allPayments.length > 0 ? `last ${allPayments.length}` : '0'}</span>
        </h2>

        {allPayments.length === 0 ? (
          <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center">
            <p class="text-sm text-slate-400" style="font-family: 'Inter', sans-serif;">No payments yet.</p>
          </div>
        ) : (
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-slate-100 bg-slate-50">
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">User</th>
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Amount</th>
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Status</th>
                  <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Date</th>
                  <th class="px-5 py-3"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {allPayments.map((payment) => (
                  <tr class="hover:bg-slate-50 transition">
                    <td class="px-5 py-4">
                      <p class="font-medium text-slate-900" style="font-family: 'Inter', sans-serif;">{payment.user.name ?? payment.user.email}</p>
                      <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">{payment.user.email}</p>
                    </td>
                    <td class="px-5 py-4 font-semibold text-slate-900" style="font-family: 'Inter', sans-serif;">
                      {formatCurrency(payment.amount, payment.currency)}
                    </td>
                    <td class="px-5 py-4">
                      <span class={`inline-flex text-xs font-medium px-2 py-0.5 rounded-full ${paymentStatusColor[payment.status] ?? 'bg-slate-100 text-slate-500'}`} style="font-family: 'Inter', sans-serif;">
                        {payment.status}
                      </span>
                    </td>
                    <td class="px-5 py-4 text-slate-600" style="font-family: 'Inter', sans-serif;">{formatDate(payment.created)}</td>
                    <td class="px-5 py-4 text-right">
                      <a
                        href={`https://dashboard.stripe.com/test/payments/${payment.stripePaymentIntentId}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs text-slate-500 hover:text-slate-900 underline underline-offset-2"
                        style="font-family: 'Inter', sans-serif;"
                      >
                        View →
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>
    </main>
  </div>
</BaseLayout>
