---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

let successMessage: string | null = null;
let errorMessage: string | null = null;
let showForm = false;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action') as string;

  try {
    if (action === 'create') {
      await client.mutation(api.emailTemplates.create, {
        name: (data.get('name') as string).trim(),
        subject: (data.get('subject') as string).trim(),
        htmlBody: (data.get('htmlBody') as string).trim(),
      });
      successMessage = 'Template created.';
    }
  } catch {
    errorMessage = 'Failed to save template.';
    showForm = true;
  }
}

const templates = await client.query(api.emailTemplates.list, {});
---

<BaseLayout title="Email Templates — Admin Portal">
  <div class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300">/</span>
        <a href="/admin/communications" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Communications</a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Templates</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-1" style="font-family: 'Lexend', sans-serif;">Email Templates</h1>
          <p class="text-slate-500" style="font-family: 'Inter', sans-serif;">{templates.length} template{templates.length !== 1 ? 's' : ''} saved.</p>
        </div>
        <button
          id="toggleForm"
          class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition"
          style="font-family: 'Inter', sans-serif;"
        >
          + New template
        </button>
      </div>

      {successMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-700" style="font-family: 'Inter', sans-serif;">
          {successMessage}
        </div>
      )}
      {errorMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700" style="font-family: 'Inter', sans-serif;">
          {errorMessage}
        </div>
      )}

      <!-- Create form -->
      <div id="createForm" class={`bg-white rounded-2xl border border-slate-200 mb-8 overflow-hidden ${showForm ? '' : 'hidden'}`}>
        <div class="px-6 py-5 border-b border-slate-100">
          <h2 class="text-base font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">New template</h2>
        </div>
        <form method="POST" class="px-6 py-5 flex flex-col gap-5">
          <input type="hidden" name="action" value="create" />
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Template name</label>
            <input
              type="text"
              name="name"
              required
              placeholder="e.g. Welcome email"
              class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent"
              style="font-family: 'Inter', sans-serif;"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Default subject</label>
            <input
              type="text"
              name="subject"
              required
              placeholder="e.g. Welcome to our platform!"
              class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent"
              style="font-family: 'Inter', sans-serif;"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">HTML body</label>
            <textarea
              name="htmlBody"
              rows="10"
              required
              placeholder="<p>Hello,</p>&#10;<p>Your message here.</p>"
              class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent resize-y font-mono"
            ></textarea>
          </div>
          <div class="flex justify-end gap-3">
            <button type="button" id="cancelForm" class="text-sm font-semibold text-slate-500 hover:text-slate-900 transition px-5 py-2.5 rounded-xl border border-slate-200 bg-slate-50" style="font-family: 'Inter', sans-serif;">
              Cancel
            </button>
            <button type="submit" class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition" style="font-family: 'Inter', sans-serif;">
              Save template
            </button>
          </div>
        </form>
      </div>

      <!-- Template list -->
      {templates.length === 0 ? (
        <div class="bg-white rounded-2xl border border-slate-200 px-6 py-16 text-center">
          <p class="text-sm font-medium text-slate-500 mb-1" style="font-family: 'Inter', sans-serif;">No templates yet</p>
          <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">Create your first template to reuse subjects and HTML bodies across Compose and Broadcast.</p>
        </div>
      ) : (
        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-100">
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Name</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Default subject</th>
                <th class="px-6 py-3"></th>
              </tr>
            </thead>
            <tbody>
              {templates.map((t) => (
                <tr class="border-b border-slate-100 last:border-0 hover:bg-slate-50 transition">
                  <td class="px-6 py-4">
                    <p class="font-medium text-slate-900" style="font-family: 'Inter', sans-serif;">{t.name}</p>
                  </td>
                  <td class="px-6 py-4 text-slate-500" style="font-family: 'Inter', sans-serif;">{t.subject}</td>
                  <td class="px-6 py-4 text-right">
                    <a
                      href={`/admin/communications/templates/${t._id}`}
                      class="text-xs font-semibold text-slate-600 hover:text-slate-900 transition"
                      style="font-family: 'Inter', sans-serif;"
                    >
                      Edit →
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </main>
  </div>
</BaseLayout>

<script>
  const toggleBtn = document.getElementById('toggleForm');
  const cancelBtn = document.getElementById('cancelForm');
  const form = document.getElementById('createForm');

  toggleBtn?.addEventListener('click', () => form?.classList.toggle('hidden'));
  cancelBtn?.addEventListener('click', () => form?.classList.add('hidden'));
</script>
