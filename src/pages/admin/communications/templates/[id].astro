---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/communications/templates');

const template = await client.query(api.emailTemplates.get, { id: id as any });
if (!template) return Astro.redirect('/admin/communications/templates');

let successMessage: string | null = null;
let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action') as string;

  try {
    if (action === 'update') {
      await client.mutation(api.emailTemplates.update, {
        id: id as any,
        name: (data.get('name') as string).trim(),
        subject: (data.get('subject') as string).trim(),
        htmlBody: (data.get('htmlBody') as string).trim(),
      });
      successMessage = 'Template saved.';
    } else if (action === 'delete') {
      await client.mutation(api.emailTemplates.remove, { id: id as any });
      return Astro.redirect('/admin/communications/templates');
    }
  } catch {
    errorMessage = 'Save failed. Please try again.';
  }
}

// Re-fetch after potential update
const current = successMessage
  ? await client.query(api.emailTemplates.get, { id: id as any })
  : template;
---

<BaseLayout title={`Edit Template — Admin Portal`}>
  <div class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300">/</span>
        <a href="/admin/communications" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Communications</a>
        <span class="text-slate-300">/</span>
        <a href="/admin/communications/templates" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Templates</a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-semibold text-slate-900 truncate max-w-48" style="font-family: 'Lexend', sans-serif;">{current?.name ?? template.name}</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-1" style="font-family: 'Lexend', sans-serif;">Edit Template</h1>
          <p class="text-slate-500 font-mono text-xs">{id}</p>
        </div>
        <div class="flex gap-2">
          <a href={`/admin/communications/compose`} class="text-xs font-semibold text-sky-600 hover:text-sky-800 border border-sky-200 bg-sky-50 px-4 py-2 rounded-xl transition" style="font-family: 'Inter', sans-serif;">
            Use in Compose
          </a>
          <a href={`/admin/communications/broadcast`} class="text-xs font-semibold text-rose-600 hover:text-rose-800 border border-rose-200 bg-rose-50 px-4 py-2 rounded-xl transition" style="font-family: 'Inter', sans-serif;">
            Use in Broadcast
          </a>
        </div>
      </div>

      {successMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-700" style="font-family: 'Inter', sans-serif;">
          {successMessage}
        </div>
      )}
      {errorMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700" style="font-family: 'Inter', sans-serif;">
          {errorMessage}
        </div>
      )}

      <!-- Edit form -->
      <section class="bg-white rounded-2xl border border-slate-200 mb-6 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100">
          <h2 class="text-base font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Template details</h2>
        </div>
        <form method="POST" class="px-6 py-5 flex flex-col gap-5">
          <input type="hidden" name="action" value="update" />
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Template name</label>
            <input
              type="text"
              name="name"
              required
              value={current?.name ?? template.name}
              class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent"
              style="font-family: 'Inter', sans-serif;"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Default subject</label>
            <input
              type="text"
              name="subject"
              required
              value={current?.subject ?? template.subject}
              class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent"
              style="font-family: 'Inter', sans-serif;"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">HTML body</label>
            <textarea
              name="htmlBody"
              rows="14"
              required
              class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent resize-y font-mono"
            >{current?.htmlBody ?? template.htmlBody}</textarea>
          </div>
          <div class="flex justify-end">
            <button type="submit" class="text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition" style="font-family: 'Inter', sans-serif;">
              Save template
            </button>
          </div>
        </form>
      </section>

      <!-- Danger zone -->
      <section class="bg-white rounded-2xl border border-red-200 overflow-hidden">
        <div class="px-6 py-5 border-b border-red-100">
          <h2 class="text-base font-semibold text-red-700" style="font-family: 'Lexend', sans-serif;">Danger Zone</h2>
        </div>
        <div class="px-6 py-5 flex items-start justify-between gap-6">
          <div>
            <p class="text-sm font-medium text-slate-900" style="font-family: 'Inter', sans-serif;">Delete this template</p>
            <p class="text-xs text-slate-500 mt-0.5" style="font-family: 'Inter', sans-serif;">Permanently removes the template. Existing sent emails are unaffected.</p>
          </div>
          <form method="POST" onsubmit="return confirm('Delete this template? This cannot be undone.')">
            <input type="hidden" name="action" value="delete" />
            <button type="submit" class="shrink-0 text-xs font-semibold text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 border border-red-200 px-4 py-2 rounded-xl transition" style="font-family: 'Inter', sans-serif;">
              Delete template
            </button>
          </form>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
