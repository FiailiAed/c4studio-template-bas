---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SignOutButton, UserButton } from '@clerk/astro/components';
import { getAuthedConvex } from '@lib/convex';
import { api } from '@convex/api';
import { getPostHogServer } from '@lib/posthog-server';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const token = await Astro.locals.auth().getToken({ template: 'convex' });
const client = getAuthedConvex(token);

const currentUser = await client.query(api.users.getByClerkId, { clerkId: userId });
if (!currentUser) return Astro.redirect('/onboarding');
if (currentUser.role !== 'admin') return Astro.redirect('/dashboard');

let successMessage: string | null = null;
let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const subject = (data.get('subject') as string)?.trim();
  const htmlBody = (data.get('htmlBody') as string)?.trim();
  const templateId = (data.get('templateId') as string) || undefined;

  try {
    await client.action(api.email.sendBroadcast, {
      subject,
      htmlBody,
      templateId: templateId as any,
    });
    successMessage = 'Broadcast sent successfully.';
    const posthog = getPostHogServer();
    posthog.capture({
      distinctId: userId,
      event: 'email_broadcast_sent',
      properties: {
        subject,
        used_template: !!templateId,
      },
    });
  } catch (err) {
    errorMessage = err instanceof Error ? err.message : 'Failed to send broadcast.';
  }
}

const [users, templates] = await Promise.all([
  client.query(api.users.list, {}),
  client.query(api.emailTemplates.list, {}),
]);
---

<BaseLayout title="Broadcast — Admin Portal">
  <div class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Admin Portal</a>
        <span class="text-slate-300">/</span>
        <a href="/admin/communications" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Communications</a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Broadcast</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Home</a>
        <UserButton />
        <SignOutButton>
          <button class="text-sm text-slate-500 hover:text-slate-900 transition" style="font-family: 'Inter', sans-serif;">Sign out</button>
        </SignOutButton>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-1" style="font-family: 'Lexend', sans-serif;">Broadcast</h1>
          <p class="text-slate-500" style="font-family: 'Inter', sans-serif;">Send an email to all registered users at once.</p>
        </div>
      </div>

      <!-- Recipient count callout -->
      <div class={`mb-6 px-5 py-4 rounded-xl border flex items-center gap-3 ${users.length === 0 ? 'bg-amber-50 border-amber-200' : 'bg-sky-50 border-sky-200'}`}>
        <svg class={`w-5 h-5 shrink-0 ${users.length === 0 ? 'text-amber-500' : 'text-sky-500'}`} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/>
        </svg>
        <p class={`text-sm font-medium ${users.length === 0 ? 'text-amber-700' : 'text-sky-700'}`} style="font-family: 'Inter', sans-serif;">
          {users.length === 0
            ? 'No registered users yet. The broadcast will fail until at least one user registers.'
            : `This email will be sent to all ${users.length} registered user${users.length !== 1 ? 's' : ''}.`}
        </p>
      </div>

      {successMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-700" style="font-family: 'Inter', sans-serif;">
          {successMessage}
        </div>
      )}
      {errorMessage && (
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-sm text-red-700" style="font-family: 'Inter', sans-serif;">
          {errorMessage}
        </div>
      )}

      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100">
          <h2 class="text-base font-semibold text-slate-900" style="font-family: 'Lexend', sans-serif;">Broadcast message</h2>
          <p class="text-sm text-slate-500 mt-0.5" style="font-family: 'Inter', sans-serif;">Sent to all {users.length} registered user{users.length !== 1 ? 's' : ''}.</p>
        </div>
        <form method="POST" class="px-6 py-5 flex flex-col gap-5" onsubmit={`return confirm('Send this email to all ${users.length} registered users?')`}>
          <!-- Template picker -->
          {templates.length > 0 && (
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Load template (optional)</label>
              <select
                id="templatePicker"
                class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent"
                style="font-family: 'Inter', sans-serif;"
              >
                <option value="">— select a template —</option>
                {templates.map((t) => (
                  <option value={t._id} data-subject={t.subject} data-body={t.htmlBody}>{t.name}</option>
                ))}
              </select>
            </div>
          )}

          <input type="hidden" id="templateIdField" name="templateId" value="" />

          <!-- Subject -->
          <div class="flex flex-col gap-1.5">
            <label for="subject" class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              placeholder="Your subject line"
              class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent"
              style="font-family: 'Inter', sans-serif;"
            />
          </div>

          <!-- HTML Body -->
          <div class="flex flex-col gap-1.5">
            <label for="htmlBody" class="text-xs font-semibold text-slate-600 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">HTML Body</label>
            <textarea
              id="htmlBody"
              name="htmlBody"
              rows="14"
              required
              placeholder="<p>Hello,</p>&#10;<p>Your message here.</p>"
              class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent resize-y font-mono"
            ></textarea>
            <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">Write valid HTML. A plain-text fallback is generated automatically.</p>
          </div>

          <div class="flex justify-end pt-1">
            <button
              type="submit"
              disabled={users.length === 0}
              class="text-sm font-semibold bg-rose-600 text-white px-6 py-2.5 rounded-xl hover:bg-rose-700 transition flex items-center gap-2 disabled:opacity-40 disabled:cursor-not-allowed"
              style="font-family: 'Inter', sans-serif;"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 1 8.835-2.535m0 0A23.74 23.74 0 0 1 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46"/>
              </svg>
              Send to {users.length} user{users.length !== 1 ? 's' : ''}
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  const picker = document.getElementById('templatePicker') as HTMLSelectElement | null;
  if (picker) {
    picker.addEventListener('change', () => {
      const selected = picker.options[picker.selectedIndex];
      const subject = selected.dataset.subject ?? '';
      const body = selected.dataset.body ?? '';
      const templateId = selected.value;

      const subjectEl = document.getElementById('subject') as HTMLInputElement | null;
      const bodyEl = document.getElementById('htmlBody') as HTMLTextAreaElement | null;
      const templateIdEl = document.getElementById('templateIdField') as HTMLInputElement | null;

      if (subjectEl && subject) subjectEl.value = subject;
      if (bodyEl && body) bodyEl.value = body;
      if (templateIdEl) templateIdEl.value = templateId;
    });
  }
</script>
