---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { enforcePageStatus } from '@lib/pageStatus';

const redirect = await enforcePageStatus('/funnels', Astro);
if (redirect) return redirect;

const settings = await convex.query(api.settings.get, {});
if (settings?.funnelsEnabled === false) return Astro.redirect('/404');

const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const funnel = await convex.query(api.funnels.getBySlug, { slug });
if (!funnel || !funnel.published) return Astro.redirect('/404');
---

<BaseLayout
  title={`${funnel.name} — ${appName}`}
  description={funnel.description ?? `${funnel.name} — ${appName}`}
>
  <Header slot="header" appName={appName} />

  <!-- Hero -->
  <section class="bg-slate-900 text-white py-24 md:py-36 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-600/10 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-40 -left-40 w-[500px] h-[500px] rounded-full bg-indigo-600/10 blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6" style="font-family: 'Inter', sans-serif;">
        {appName}
      </p>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight leading-[1.05] mb-6" style="font-family: 'Lexend', sans-serif;">
        {funnel.headline ?? funnel.name}
      </h1>
      {(funnel.subheadline ?? funnel.description) && (
        <p class="text-lg md:text-xl text-slate-400 leading-relaxed max-w-2xl mx-auto mb-10" style="font-family: 'Inter', sans-serif;">
          {funnel.subheadline ?? funnel.description}
        </p>
      )}
      <a
        href={funnel.ctaHref ?? '/contact'}
        class="inline-flex items-center gap-2 bg-white text-slate-900 font-semibold px-8 py-4 rounded-2xl hover:bg-slate-100 transition text-base"
        style="font-family: 'Inter', sans-serif;"
      >
        {funnel.ctaLabel ?? 'Get started'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
  </section>

  <CTA
    heading={"Ready to work\ntogether?"}
    subheading="Tell us about your project. We'll get back to you within one business day."
    primaryCta={{ label: 'Get in touch', href: '/contact' }}
    secondaryCta={{ label: 'See our services', href: '/services' }}
  />

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
