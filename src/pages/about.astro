---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import About from '@marketing/About.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';

const settings = await convex.query(api.settings.get, {});
const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const values = [
  {
    title: 'Clarity over cleverness',
    body: 'We choose the simplest solution that works. No unnecessary complexity, no over-engineering.',
    icon: 'M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
  },
  {
    title: 'Move fast, communicate faster',
    body: 'Speed matters. We ship iteratively and keep you in the loop at every step — no black-box builds.',
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
  },
  {
    title: 'Own the outcome',
    body: "We're not order-takers. If something won't work, we'll say so — and suggest what will.",
    icon: 'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  },
  {
    title: 'Long-term thinking',
    body: 'We build for maintainability and scale, not just the demo. Code you can hand off, extend, and be proud of.',
    icon: 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  },
];

const process = [
  {
    step: '01',
    title: 'Discovery',
    body: 'We listen before we build. A focused kickoff to understand your goals, users, constraints, and what success looks like.',
  },
  {
    step: '02',
    title: 'Blueprint',
    body: 'A clear plan before a single line of code: architecture decisions, design direction, and a realistic timeline.',
  },
  {
    step: '03',
    title: 'Build',
    body: 'Iterative development with regular demos. You see real progress, not status updates. Feedback shapes the product in real time.',
  },
  {
    step: '04',
    title: 'Launch & Beyond',
    body: 'A smooth handoff — or we stay on as your ongoing partner. Either way, you leave with something that works and a team that stands behind it.',
  },
];
---

<BaseLayout
  title={`About — ${appName}`}
  description={`Learn about ${appName} — our story, values, and how we work.`}
>
  <Header slot="header" appName={appName} />

  <!-- Hero -->
  <section class="bg-slate-900 text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-600/20 blur-3xl pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto px-6">
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-sky-400 uppercase tracking-widest mb-6" style="font-family: 'Inter', sans-serif;">
        <span class="w-6 h-px bg-sky-400"></span>
        About us
      </p>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight leading-[1.05] mb-6" style="font-family: 'Lexend', sans-serif;">
        We build with<br />purpose.
      </h1>
      <p class="text-lg text-slate-400 leading-relaxed max-w-xl" style="font-family: 'Inter', sans-serif;">
        {description}
      </p>
    </div>
  </section>

  <!-- Story section (reuses the About marketing component) -->
  <About
    eyebrow="Our story"
    heading={"Founded on\ngreat work."}
    body={[
      `${appName} started with a simple frustration: too many digital agencies delivering slow, bloated, over-budgeted projects that clients couldn't maintain after handoff.`,
      "We built a different kind of studio — small by design, senior by default. Every project gets experienced eyes on it from day one, not just at the review stage.",
      "We work across industries and company sizes, but our approach stays the same: listen first, plan clearly, build fast, and ship something we're genuinely proud of.",
    ]}
    ctaHref="/contact"
    ctaLabel="Start a conversation"
  />

  <!-- Values -->
  <section class="bg-white py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-16">
        <p class="inline-flex items-center gap-2 text-xs font-semibold text-blue-600 uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">
          <span class="w-6 h-px bg-blue-600"></span>
          How we work
        </p>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight leading-tight" style="font-family: 'Lexend', sans-serif;">
          Principles we<br />don't compromise on.
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {values.map(({ title, body, icon }) => (
          <div class="p-7 rounded-2xl border border-slate-200 bg-slate-50">
            <div class="w-10 h-10 rounded-xl bg-slate-900 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-slate-900 mb-2" style="font-family: 'Lexend', sans-serif;">{title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed" style="font-family: 'Inter', sans-serif;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="bg-slate-50 py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mb-16">
        <p class="inline-flex items-center gap-2 text-xs font-semibold text-blue-600 uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">
          <span class="w-6 h-px bg-blue-600"></span>
          Our process
        </p>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight leading-tight" style="font-family: 'Lexend', sans-serif;">
          How a project<br />actually goes.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map(({ step, title, body }) => (
          <div class="relative p-6 rounded-2xl bg-white border border-slate-200">
            <p class="text-4xl font-bold text-slate-100 mb-4 leading-none" style="font-family: 'Lexend', sans-serif;">{step}</p>
            <h3 class="text-base font-semibold text-slate-900 mb-2" style="font-family: 'Lexend', sans-serif;">{title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed" style="font-family: 'Inter', sans-serif;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={"Ready to work\ntogether?"}
    subheading="Tell us about your project. We'll get back to you within one business day."
    primaryCta={{ label: 'Get in touch', href: '/contact' }}
    secondaryCta={{ label: 'See our services', href: '/services' }}
  />

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
