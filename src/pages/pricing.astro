---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';

const [tiers, settings] = await Promise.all([
  convex.query(api.pricing.listPublished, {}),
  convex.query(api.settings.get, {}),
]);

const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const billingLabels: Record<string, string> = {
  monthly: '/mo',
  annual: '/yr',
  one_time: '',
  custom: '',
};
---

<BaseLayout
  title={`Pricing — ${appName}`}
  description={`Simple, transparent pricing from ${appName}. Choose the plan that fits your needs.`}
>
  <Header slot="header" appName={appName} />

  <!-- Hero -->
  <section class="bg-slate-900 pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-blue-400 uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">
        <span class="w-6 h-px bg-blue-400"></span>
        Pricing
        <span class="w-6 h-px bg-blue-400"></span>
      </p>
      <h1 class="text-5xl md:text-6xl font-bold text-white tracking-tight leading-tight" style="font-family: 'Lexend', sans-serif;">
        Simple, transparent<br />pricing.
      </h1>
      <p class="text-slate-400 mt-4 max-w-xl mx-auto text-lg" style="font-family: 'Inter', sans-serif;">
        No surprises. Pick the plan that fits your business and get started today.
      </p>
    </div>
  </section>

  <!-- Pricing grid -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      {tiers.length === 0 ? (
        <div class="max-w-md mx-auto text-center py-20">
          <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold text-slate-900 mb-2" style="font-family: 'Lexend', sans-serif;">Pricing coming soon</h2>
          <p class="text-slate-500 mb-6" style="font-family: 'Inter', sans-serif;">We're finalising our plans. Contact us for details and a custom quote.</p>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-900 text-white text-sm font-semibold hover:bg-slate-700 transition"
            style="font-family: 'Inter', sans-serif;"
          >
            Get in touch
          </a>
        </div>
      ) : (
        <div class={`grid grid-cols-1 gap-8 ${tiers.length === 2 ? 'md:grid-cols-2 max-w-3xl mx-auto' : tiers.length >= 3 ? 'md:grid-cols-2 lg:grid-cols-3' : 'max-w-sm mx-auto'}`}>
          {tiers.map((tier) => {
            const priceDisplay = tier.priceLabel
              ? tier.priceLabel
              : tier.price !== undefined && tier.price !== null
              ? `$${tier.price.toLocaleString()}`
              : 'Contact us';
            const billingLabel = tier.price !== undefined && !tier.priceLabel
              ? (billingLabels[tier.billingPeriod] ?? '')
              : '';

            return (
              <div class={`relative flex flex-col rounded-2xl p-8 ${
                tier.highlighted
                  ? 'bg-slate-900 text-white ring-2 ring-slate-900'
                  : 'bg-white text-slate-900 border border-slate-200'
              }`}>
                {tier.highlighted && (
                  <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                    <span class="bg-blue-600 text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">
                      Most popular
                    </span>
                  </div>
                )}

                <!-- Tier header -->
                <div class="mb-6">
                  <h2 class={`text-xl font-bold tracking-tight ${tier.highlighted ? 'text-white' : 'text-slate-900'}`} style="font-family: 'Lexend', sans-serif;">
                    {tier.name}
                  </h2>
                  {tier.description && (
                    <p class={`text-sm mt-1 ${tier.highlighted ? 'text-slate-400' : 'text-slate-500'}`} style="font-family: 'Inter', sans-serif;">
                      {tier.description}
                    </p>
                  )}
                </div>

                <!-- Price -->
                <div class="mb-8">
                  <div class="flex items-end gap-1">
                    <span class={`text-4xl font-bold tracking-tight ${tier.highlighted ? 'text-white' : 'text-slate-900'}`} style="font-family: 'Lexend', sans-serif;">
                      {priceDisplay}
                    </span>
                    {billingLabel && (
                      <span class={`text-sm mb-1 ${tier.highlighted ? 'text-slate-400' : 'text-slate-500'}`} style="font-family: 'Inter', sans-serif;">
                        {billingLabel}
                      </span>
                    )}
                  </div>
                </div>

                <!-- Features -->
                {tier.features.length > 0 && (
                  <ul class="flex flex-col gap-3 mb-8 flex-1">
                    {tier.features.map((feature) => (
                      <li class="flex items-start gap-3">
                        <svg class={`w-5 h-5 shrink-0 mt-0.5 ${tier.highlighted ? 'text-blue-400' : 'text-emerald-500'}`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
                        </svg>
                        <span class={`text-sm ${tier.highlighted ? 'text-slate-300' : 'text-slate-600'}`} style="font-family: 'Inter', sans-serif;">
                          {feature}
                        </span>
                      </li>
                    ))}
                  </ul>
                )}

                <!-- CTA -->
                <a
                  href={tier.ctaHref}
                  class={`w-full text-center px-6 py-3 rounded-xl text-sm font-semibold transition ${
                    tier.highlighted
                      ? 'bg-white text-slate-900 hover:bg-slate-100'
                      : 'bg-slate-900 text-white hover:bg-slate-700'
                  }`}
                  style="font-family: 'Inter', sans-serif;"
                >
                  {tier.ctaLabel}
                </a>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CTA />
  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
