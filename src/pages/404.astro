---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';

const settings = await convex.query(api.settings.get, {});
const appName = settings?.appName ?? 'c4studio';
---

<BaseLayout title={`404 — Page Not Found | ${appName}`} description="The page you're looking for doesn't exist.">
  <Header slot="header" appName={appName} />

  <section class="min-h-[70vh] flex items-center justify-center bg-white px-6 py-24">
    <div class="max-w-lg text-center">
      <!-- 404 display -->
      <p class="text-8xl md:text-9xl font-bold text-slate-100 leading-none select-none" style="font-family: 'Lexend', sans-serif;">
        404
      </p>

      <div class="-mt-6 relative">
        <h1 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3" style="font-family: 'Lexend', sans-serif;">
          Page not found
        </h1>
        <p class="text-slate-500 leading-relaxed mb-8" style="font-family: 'Inter', sans-serif;">
          The page you're looking for doesn't exist or has been moved.
        </p>

        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/"
            class="inline-flex items-center gap-2 text-sm font-semibold bg-slate-900 text-white px-5 py-2.5 rounded-xl hover:bg-slate-700 transition"
            style="font-family: 'Inter', sans-serif;"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
            </svg>
            Go home
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-5 py-2.5 rounded-xl transition"
            style="font-family: 'Inter', sans-serif;"
          >
            Contact us
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" appName={appName} />
</BaseLayout>
