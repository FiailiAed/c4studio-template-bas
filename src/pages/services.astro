---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import Services from '@marketing/Services.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { enforcePageStatus } from '@lib/pageStatus';

const redirect = await enforcePageStatus('/services', Astro);
if (redirect) return redirect;

const settings = await convex.query(api.settings.get, {});
const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

// Deep-dive sections — anchors match Footer nav links: #strategy, #design, #development, #growth
const deepDives = [
  {
    id: 'strategy',
    eyebrow: 'Strategy & Discovery',
    heading: 'Start with\nclarity.',
    body: "Most projects fail before a line of code is written — because the problem wasn't well-defined. Our discovery process surfaces the real goal, the actual user, and the constraints that matter, so every decision downstream is grounded in something real.",
    points: [
      'Stakeholder interviews and goal alignment',
      'User research and persona development',
      'Competitive landscape analysis',
      'Technical feasibility and risk assessment',
      'Roadmap and prioritization framework',
    ],
    icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
    flip: false,
  },
  {
    id: 'design',
    eyebrow: 'Design & Branding',
    heading: 'Interfaces people\nactually use.',
    body: "Good design isn't decoration — it's the difference between a product people adopt and one they abandon. We design for the user first, the brand second, and the pixel grid third. The result is work that's both beautiful and functional.",
    points: [
      'Brand identity and visual language',
      'UX wireframing and user flows',
      'High-fidelity UI design and prototyping',
      'Design system creation and documentation',
      'Accessibility and responsive design',
    ],
    icon: 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
    flip: true,
  },
  {
    id: 'development',
    eyebrow: 'Development',
    heading: 'Built to last,\nnot just to demo.',
    body: "We write code that the next developer can read, the next engineer can extend, and the next founder can hand off without a rewrite. Fast shipping doesn't mean cutting corners — it means making the right calls early.",
    points: [
      'Full-stack web application development',
      'API design and third-party integrations',
      'Performance optimization and Core Web Vitals',
      'Testing, QA, and deployment pipelines',
      'Documentation and developer handoff',
    ],
    icon: 'M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5',
    flip: false,
  },
  {
    id: 'growth',
    eyebrow: 'Growth & Analytics',
    heading: 'Ship it. Measure it.\nImprove it.',
    body: "Launch is day one, not the finish line. We set up the instrumentation to know what's working, identify what isn't, and make data-driven bets on what to build next. Gut feel has a place — but it works better with evidence.",
    points: [
      'Analytics setup and event tracking',
      'Conversion rate optimization (CRO)',
      'A/B testing and experiment design',
      'Funnel analysis and user behavior',
      'Monthly reporting and growth recommendations',
    ],
    icon: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941',
    flip: true,
  },
];
---

<BaseLayout
  title={`Services — ${appName}`}
  description={`Services offered by ${appName} — strategy, design, development, and growth.`}
>
  <Header slot="header" appName={appName} />

  <!-- Hero -->
  <section class="bg-slate-900 text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-600/20 blur-3xl pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto px-6">
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-sky-400 uppercase tracking-widest mb-6" style="font-family: 'Inter', sans-serif;">
        <span class="w-6 h-px bg-sky-400"></span>
        What we do
      </p>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight leading-[1.05] mb-6" style="font-family: 'Lexend', sans-serif;">
        Services built<br />for results.
      </h1>
      <p class="text-lg text-slate-400 leading-relaxed max-w-xl" style="font-family: 'Inter', sans-serif;">
        From strategy through launch and beyond — everything you need to design, build, and grow a digital product.
      </p>
    </div>
  </section>

  <!-- Service card overview grid (reuses marketing component, CTA points to contact) -->
  <Services
    eyebrow="Full service"
    heading={"Everything under\none roof."}
    subheading="We cover every stage of the digital product lifecycle so you don't have to stitch together four different agencies."
    ctaHref="/contact"
    ctaLabel="Start a project"
  />

  <!-- Deep-dive sections with anchor IDs for Footer nav links -->
  {deepDives.map(({ id, eyebrow, heading, body, points, icon, flip }) => (
    <section id={id} class={`py-24 md:py-32 ${flip ? 'bg-slate-50' : 'bg-white'}`}>
      <div class="max-w-6xl mx-auto px-6">
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-16 items-center ${flip ? 'lg:grid-flow-dense' : ''}`}>

          <!-- Text -->
          <div class={flip ? 'lg:col-start-2' : ''}>
            <p class="inline-flex items-center gap-2 text-xs font-semibold text-blue-600 uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">
              <span class="w-6 h-px bg-blue-600"></span>
              {eyebrow}
            </p>
            <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight leading-tight mb-6 whitespace-pre-line" style="font-family: 'Lexend', sans-serif;">
              {heading}
            </h2>
            <p class="text-slate-500 leading-relaxed mb-8" style="font-family: 'Inter', sans-serif;">{body}</p>
            <ul class="flex flex-col gap-3">
              {points.map((point) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-slate-900 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
                  </svg>
                  <span class="text-sm text-slate-600" style="font-family: 'Inter', sans-serif;">{point}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Visual block -->
          <div class={flip ? 'lg:col-start-1 lg:row-start-1' : ''}>
            <div class={`rounded-3xl p-10 flex items-center justify-center aspect-square ${flip ? 'bg-white border border-slate-200' : 'bg-slate-50 border border-slate-200'}`}>
              <div class="flex flex-col items-center gap-4 text-slate-300">
                <div class="w-20 h-20 rounded-2xl bg-slate-900 flex items-center justify-center">
                  <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                  </svg>
                </div>
                <p class="text-sm font-medium text-slate-400" style="font-family: 'Inter', sans-serif;">
                  {eyebrow}
                </p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <CTA
    heading={"Not sure where\nto start?"}
    subheading="Tell us what you're working on. We'll help you figure out the right scope and approach — no obligation."
    primaryCta={{ label: 'Start a conversation', href: '/contact' }}
    secondaryCta={{ label: 'Learn about us', href: '/about' }}
  />

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
