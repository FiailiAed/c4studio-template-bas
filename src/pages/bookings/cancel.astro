---
import BaseLayout from '@layouts/BaseLayout.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { verifyToken } from '@lib/tokens';
import type { Id } from '@convex/dataModel';

const bookingId = Astro.url.searchParams.get('bookingId') as Id<'bookings'> | null;
const token = Astro.url.searchParams.get('token');
const alreadyCancelled = Astro.url.searchParams.get('cancelled') === '1';

const tokenValid = !!(bookingId && token && verifyToken(`cancel:${bookingId}`, token));

let booking = null;
let bookingLink = null;

if (tokenValid && bookingId) {
  [booking, ] = await Promise.all([
    convex.query(api.bookings.get, { id: bookingId }),
  ]);
  if (booking) {
    bookingLink = await convex.query(api.bookingLinks.get, { id: booking.bookingLinkId });
  }
}

let cancelError: string | null = null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  if (data.get('action') === 'confirm-cancel' && tokenValid && bookingId && booking?.status === 'confirmed') {
    try {
      await convex.mutation(api.bookings.cancel, { id: bookingId });
      return Astro.redirect(`/bookings/cancel?bookingId=${bookingId}&token=${token}&cancelled=1`);
    } catch {
      cancelError = 'Cancellation failed. Please try again or contact us directly.';
    }
  }
}

function fmtDate(d: string) {
  const [y, m, day] = d.split('-').map(Number);
  return new Date(y, m - 1, day).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
}
function fmt12h(t: string) {
  const [h, m] = t.split(':').map(Number);
  return `${h % 12 || 12}:${String(m).padStart(2, '0')} ${h >= 12 ? 'PM' : 'AM'}`;
}
---

<BaseLayout title="Cancel Booking">
  <div class="min-h-screen bg-slate-50 flex items-center justify-center px-4 py-16">
    <div class="max-w-md w-full">

      {!tokenValid && (
        <div class="bg-white rounded-2xl border border-slate-200 px-8 py-12 text-center">
          <div class="w-14 h-14 rounded-full bg-red-50 border border-red-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
            </svg>
          </div>
          <h1 class="text-xl font-bold text-slate-900 mb-3" style="font-family: 'Lexend', sans-serif;">Invalid link</h1>
          <p class="text-sm text-slate-500" style="font-family: 'Inter', sans-serif;">This cancellation link is invalid or has expired. Please use the link from your original confirmation email.</p>
        </div>
      )}

      {tokenValid && alreadyCancelled && (
        <div class="bg-white rounded-2xl border border-slate-200 px-8 py-12 text-center">
          <div class="w-14 h-14 rounded-full bg-emerald-50 border border-emerald-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-emerald-500" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
            </svg>
          </div>
          <h1 class="text-xl font-bold text-slate-900 mb-3" style="font-family: 'Lexend', sans-serif;">Booking cancelled</h1>
          <p class="text-sm text-slate-500" style="font-family: 'Inter', sans-serif;">
            Your booking has been cancelled. If you'd like to reschedule, visit
            {bookingLink && (
              <a href={`/booking-links/${bookingLink.slug}`} class="text-slate-700 underline"> our booking page</a>
            )}.
          </p>
        </div>
      )}

      {tokenValid && !alreadyCancelled && booking && (
        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <div class="px-8 py-6 border-b border-slate-100">
            <h1 class="text-xl font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">Cancel booking</h1>
            <p class="text-sm text-slate-500 mt-1" style="font-family: 'Inter', sans-serif;">Please confirm you want to cancel this appointment.</p>
          </div>

          <div class="px-8 py-6 border-b border-slate-100">
            {booking.status === 'cancelled' ? (
              <p class="text-sm text-amber-600 bg-amber-50 border border-amber-100 rounded-xl px-4 py-3" style="font-family: 'Inter', sans-serif;">This booking has already been cancelled.</p>
            ) : (
              <div class="flex flex-col gap-3">
                <div>
                  <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Service</p>
                  <p class="text-sm font-medium text-slate-900 mt-0.5" style="font-family: 'Inter', sans-serif;">{bookingLink?.name ?? 'Appointment'}</p>
                </div>
                <div>
                  <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Date & Time</p>
                  <p class="text-sm font-medium text-slate-900 mt-0.5" style="font-family: 'Inter', sans-serif;">{fmtDate(booking.date)} at {fmt12h(booking.startTime)}</p>
                </div>
                <div>
                  <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide" style="font-family: 'Inter', sans-serif;">Name</p>
                  <p class="text-sm font-medium text-slate-900 mt-0.5" style="font-family: 'Inter', sans-serif;">{booking.name}</p>
                </div>
              </div>
            )}
          </div>

          {booking.status === 'confirmed' && (
            <div class="px-8 py-6">
              {cancelError && (
                <p class="text-sm text-red-600 bg-red-50 border border-red-100 rounded-xl px-4 py-3 mb-4" style="font-family: 'Inter', sans-serif;">{cancelError}</p>
              )}
              <form method="POST" class="flex flex-col gap-3">
                <input type="hidden" name="action" value="confirm-cancel" />
                <button type="submit"
                  class="w-full py-3 rounded-xl bg-red-600 text-white text-sm font-semibold hover:bg-red-700 transition"
                  style="font-family: 'Inter', sans-serif;">
                  Yes, cancel this booking
                </button>
                {bookingLink && (
                  <a href={`/booking-links/${bookingLink.slug}`}
                    class="w-full py-3 rounded-xl bg-slate-100 text-slate-600 text-sm font-medium hover:bg-slate-200 transition text-center"
                    style="font-family: 'Inter', sans-serif;">
                    No, keep my booking
                  </a>
                )}
              </form>
            </div>
          )}
        </div>
      )}

    </div>
  </div>
</BaseLayout>
