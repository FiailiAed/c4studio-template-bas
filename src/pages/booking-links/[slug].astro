---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import Footer from '@marketing/Footer.astro';
import BookingWidget from '@components/BookingWidget.svelte';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { enforcePageStatus } from '@lib/pageStatus';

const redirect = await enforcePageStatus('/booking-links', Astro);
if (redirect) return redirect;

const settings = await convex.query(api.settings.get, {});
const appName = settings?.appName ?? 'c4studio';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const link = await convex.query(api.bookingLinks.getBySlug, { slug });
if (!link || !link.published) return Astro.redirect('/404');

const headline = link.headline ?? link.name;
const subheadline = link.subheadline ?? link.description;
const duration = link.duration ?? 60;
---

<BaseLayout
  title={`${headline} — ${appName}`}
  description={subheadline ?? `Book a ${duration}-minute appointment with ${appName}.`}
>
  <Header slot="header" appName={appName} />

  <!-- Hero -->
  <section class="bg-slate-900 text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-600/10 blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6" style="font-family: 'Inter', sans-serif;">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
        </svg>
        {duration} min · Free
      </div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] mb-5" style="font-family: 'Lexend', sans-serif;">
        {headline}
      </h1>
      {subheadline && (
        <p class="text-lg text-slate-400 leading-relaxed max-w-xl mx-auto" style="font-family: 'Inter', sans-serif;">
          {subheadline}
        </p>
      )}
    </div>
  </section>

  <!-- Booking widget -->
  <section class="bg-slate-50 py-16 md:py-24">
    <div class="max-w-lg mx-auto px-6">
      <BookingWidget
        client:load
        bookingLinkId={link._id}
        duration={link.duration ?? 60}
        bufferTime={link.bufferTime ?? 0}
        availabilityStart={link.availabilityStart ?? '09:00'}
        availabilityEnd={link.availabilityEnd ?? '17:00'}
        availableDays={link.availableDays ?? [1, 2, 3, 4, 5]}
      />
    </div>
  </section>

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
