---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import CTA from '@marketing/CTA.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';
import { enforcePageStatus } from '@lib/pageStatus';

const redirect = await enforcePageStatus('/shops', Astro);
if (redirect) return redirect;

const settings = await convex.query(api.settings.get, {});
const appName = settings?.appName ?? 'c4studio';
const siteUrl = settings?.siteUrl ?? Astro.url.origin;
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const shop = await convex.query(api.shops.getBySlug, { slug });
if (!shop || !shop.published) return Astro.redirect('/404');

const allItems = await convex.query(api.shopItems.listByShop, { shopId: shop._id });
const items = allItems.filter((i) => i.published);

const { userId } = Astro.locals.auth();

const headline = shop.headline ?? shop.name;
const subheadline = shop.subheadline ?? shop.description;

function formatPrice(cents: number, currency: string) {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: currency.toUpperCase(),
  }).format(cents / 100);
}
---

<BaseLayout
  title={`${headline} — ${appName}`}
  description={subheadline ?? `Shop ${headline} on ${appName}.`}
>
  <Header slot="header" appName={appName} />

  <!-- Hero -->
  <section class="bg-slate-900 text-white py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-600/10 blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] mb-5" style="font-family: 'Lexend', sans-serif;">
        {headline}
      </h1>
      {subheadline && (
        <p class="text-lg text-slate-400 leading-relaxed max-w-xl mx-auto" style="font-family: 'Inter', sans-serif;">
          {subheadline}
        </p>
      )}
    </div>
  </section>

  <!-- Products -->
  <section class="bg-white py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-6">

      {!userId && (
        <div class="mb-10 flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4">
          <svg class="w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25z"/>
          </svg>
          <p class="text-sm text-slate-600" style="font-family: 'Inter', sans-serif;">
            <a href={`/sign-in?redirect_url=/shops/${slug}`} class="font-semibold text-slate-900 underline underline-offset-2">Sign in</a> to purchase.
          </p>
        </div>
      )}

      {items.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-slate-400 text-sm" style="font-family: 'Inter', sans-serif;">No products available yet.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {items.map((item) => (
            <div class="group bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-slate-300 hover:shadow-lg transition-all duration-200">
              {item.imageUrl ? (
                <div class="aspect-video bg-slate-100 overflow-hidden">
                  <img
                    src={item.imageUrl}
                    alt={item.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
              ) : (
                <div class="aspect-video bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
                  <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                  </svg>
                </div>
              )}

              <div class="p-5">
                <h3 class="font-semibold text-slate-900 mb-1" style="font-family: 'Lexend', sans-serif;">{item.name}</h3>
                {item.description && (
                  <p class="text-sm text-slate-500 leading-relaxed mb-4 line-clamp-2" style="font-family: 'Inter', sans-serif;">{item.description}</p>
                )}
                <div class="flex items-center justify-between gap-3">
                  <span class="text-lg font-bold text-slate-900" style="font-family: 'Lexend', sans-serif;">
                    {formatPrice(item.price, item.currency)}
                  </span>
                  {userId ? (
                    <form method="POST" action="/api/shop-checkout">
                      <input type="hidden" name="stripePriceId" value={item.stripePriceId} />
                      <input type="hidden" name="successUrl" value={`${siteUrl}/shops/${slug}?success=1`} />
                      <input type="hidden" name="cancelUrl" value={`${siteUrl}/shops/${slug}`} />
                      <button
                        type="submit"
                        class="text-sm font-semibold bg-slate-900 text-white px-4 py-2.5 rounded-xl hover:bg-slate-700 transition"
                        style="font-family: 'Inter', sans-serif;"
                      >
                        Buy now
                      </button>
                    </form>
                  ) : (
                    <a
                      href={`/sign-in?redirect_url=/shops/${slug}`}
                      class="text-sm font-semibold text-slate-500 bg-slate-100 px-4 py-2.5 rounded-xl hover:bg-slate-200 transition"
                      style="font-family: 'Inter', sans-serif;"
                    >
                      Sign in
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      )}

      {Astro.url.searchParams.get('success') === '1' && (
        <div class="mt-12 flex items-center gap-3 bg-emerald-50 border border-emerald-200 rounded-2xl px-5 py-4">
          <svg class="w-5 h-5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
          </svg>
          <p class="text-sm font-medium text-emerald-800" style="font-family: 'Inter', sans-serif;">Purchase complete — thank you!</p>
        </div>
      )}
    </div>
  </section>

  <CTA
    heading={"Ready to work\ntogether?"}
    subheading="Tell us about your project. We'll get back to you within one business day."
    primaryCta={{ label: 'Get in touch', href: '/contact' }}
    secondaryCta={{ label: 'See our services', href: '/services' }}
  />

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
