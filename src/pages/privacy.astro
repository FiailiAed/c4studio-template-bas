---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@marketing/Header.astro';
import Footer from '@marketing/Footer.astro';
import { convex } from '@lib/convex';
import { api } from '@convex/api';

const settings = await convex.query(api.settings.get, {});
const appName = settings?.appName ?? 'c4studio';
const siteUrl = settings?.siteUrl ?? 'https://example.com';
const supportEmail = settings?.supportEmail ?? 'hello@example.com';
const description = settings?.description ?? 'We help ambitious businesses design, build, and grow digital products that stand out.';

const lastUpdated = 'June 1, 2026';
---

<BaseLayout
  title={`Privacy Policy — ${appName}`}
  description={`Privacy Policy for ${appName}.`}
>
  <Header slot="header" appName={appName} />

  <!-- Page hero -->
  <section class="bg-slate-900 text-white py-16 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="relative max-w-3xl mx-auto px-6">
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-sky-400 uppercase tracking-widest mb-4" style="font-family: 'Inter', sans-serif;">
        <span class="w-6 h-px bg-sky-400"></span>
        Legal
      </p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight mb-4" style="font-family: 'Lexend', sans-serif;">
        Privacy Policy
      </h1>
      <p class="text-slate-400 text-sm" style="font-family: 'Inter', sans-serif;">Last updated: {lastUpdated}</p>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">
      <div class="prose-slate" style="font-family: 'Inter', sans-serif;">

        <p class="text-slate-600 leading-relaxed mb-10">
          This Privacy Policy describes how {appName} ("<strong>we</strong>," "<strong>us</strong>," or "<strong>our</strong>") collects, uses, and shares information about you when you visit <a href={siteUrl} class="text-slate-900 underline underline-offset-2 hover:text-slate-600 transition">{siteUrl}</a> (the "Site") or contact us through our services.
        </p>

        <!-- Section -->
        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">1. Information We Collect</h2>
          <p class="text-slate-600 leading-relaxed mb-4">We collect information you provide directly to us, including:</p>
          <ul class="list-disc list-outside pl-5 text-slate-600 leading-relaxed space-y-2">
            <li><strong class="text-slate-800">Contact form submissions</strong> — your name, email address, phone number, and message when you reach out through our contact form.</li>
            <li><strong class="text-slate-800">Account information</strong> — your name and email address when you create an account.</li>
            <li><strong class="text-slate-800">Communications</strong> — any messages or correspondence you send us.</li>
          </ul>
          <p class="text-slate-600 leading-relaxed mt-4">We also collect certain information automatically when you visit the Site, including your IP address, browser type, operating system, referring URLs, and pages viewed. We use PostHog for analytics and Vercel for hosting and performance monitoring.</p>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">2. How We Use Your Information</h2>
          <p class="text-slate-600 leading-relaxed mb-4">We use the information we collect to:</p>
          <ul class="list-disc list-outside pl-5 text-slate-600 leading-relaxed space-y-2">
            <li>Respond to your inquiries and provide the services you request.</li>
            <li>Send you administrative communications, confirmations, and updates.</li>
            <li>Send you follow-up messages related to your inquiry, including via SMS if you provided a phone number.</li>
            <li>Improve the Site and our services.</li>
            <li>Comply with legal obligations.</li>
          </ul>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">3. SMS Communications</h2>
          <p class="text-slate-600 leading-relaxed mb-4">If you provide your phone number through our contact form, you consent to receive SMS messages from us related to your inquiry. Message and data rates may apply. You can opt out at any time by replying <strong class="text-slate-800">STOP</strong> to any message we send. For help, reply <strong class="text-slate-800">HELP</strong>.</p>
          <p class="text-slate-600 leading-relaxed">We do not use your phone number for marketing unrelated to your inquiry and do not sell or share it with third parties for their marketing purposes.</p>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">4. Sharing of Information</h2>
          <p class="text-slate-600 leading-relaxed mb-4">We do not sell your personal information. We may share your information with:</p>
          <ul class="list-disc list-outside pl-5 text-slate-600 leading-relaxed space-y-2">
            <li><strong class="text-slate-800">Service providers</strong> — vendors who help us operate the Site and deliver services, including Convex (database), Clerk (authentication), Resend (email), and Vercel (hosting). These providers are contractually bound to protect your data.</li>
            <li><strong class="text-slate-800">Legal requirements</strong> — if required by law or to protect our rights and the safety of others.</li>
          </ul>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">5. Data Retention</h2>
          <p class="text-slate-600 leading-relaxed">We retain contact form submissions and account information for as long as necessary to provide our services and comply with legal obligations. You may request deletion of your data at any time by contacting us.</p>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">6. Your Rights</h2>
          <p class="text-slate-600 leading-relaxed mb-4">Depending on where you live, you may have the right to:</p>
          <ul class="list-disc list-outside pl-5 text-slate-600 leading-relaxed space-y-2">
            <li>Access the personal information we hold about you.</li>
            <li>Request correction of inaccurate information.</li>
            <li>Request deletion of your information.</li>
            <li>Opt out of certain communications.</li>
          </ul>
          <p class="text-slate-600 leading-relaxed mt-4">To exercise any of these rights, contact us at <a href={`mailto:${supportEmail}`} class="text-slate-900 underline underline-offset-2 hover:text-slate-600 transition">{supportEmail}</a>.</p>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">7. Cookies</h2>
          <p class="text-slate-600 leading-relaxed">We use cookies and similar tracking technologies for analytics (PostHog) and authentication (Clerk). By using the Site, you consent to our use of cookies. You can control cookie settings through your browser, though disabling cookies may affect Site functionality.</p>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">8. Children's Privacy</h2>
          <p class="text-slate-600 leading-relaxed">Our Site is not directed to children under the age of 13. We do not knowingly collect personal information from children. If you believe we have inadvertently collected such information, contact us and we will promptly delete it.</p>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">9. Changes to This Policy</h2>
          <p class="text-slate-600 leading-relaxed">We may update this Privacy Policy from time to time. When we do, we'll update the "Last updated" date at the top of this page. Your continued use of the Site after any changes constitutes your acceptance of the updated policy.</p>
        </div>

        <div class="mb-10">
          <h2 class="text-xl font-bold text-slate-900 mb-4" style="font-family: 'Lexend', sans-serif;">10. Contact Us</h2>
          <p class="text-slate-600 leading-relaxed">
            If you have any questions about this Privacy Policy, reach us at:<br />
            <a href={`mailto:${supportEmail}`} class="text-slate-900 underline underline-offset-2 hover:text-slate-600 transition">{supportEmail}</a>
          </p>
        </div>

        <!-- Divider -->
        <div class="border-t border-slate-100 pt-8 mt-8">
          <p class="text-xs text-slate-400" style="font-family: 'Inter', sans-serif;">
            This is a template document. Consult a qualified attorney to ensure this policy meets the legal requirements applicable to your business and jurisdiction.
          </p>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" appName={appName} tagline={description} />
</BaseLayout>
